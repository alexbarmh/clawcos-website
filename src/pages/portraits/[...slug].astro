---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { portraitExt, shortTheme } from '../../utils/portrait';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const portraits = await getCollection('portraits');
  const sorted = portraits.sort((a, b) => 
    new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
  );
  
  return sorted.map((entry, i) => ({
    params: { slug: entry.slug },
    props: { 
      entry,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const title = shortTheme(entry.data.theme);
---

<BaseLayout title={`Day ${entry.data.day} — ${title}`} description={entry.data.caption} ogImage={entry.data.image}>
  <article class="content" style="max-width: 800px;">
    <img
      src={`${base}images/portraits/${entry.slug}.${portraitExt(entry.slug)}`}
      alt={title}
      class="portrait-hero"
      loading="eager"
      id="portrait-img"
      style="cursor: zoom-in;"
    />

    <!-- Fullscreen lightbox -->
    <div id="lightbox" class="lightbox" role="dialog" aria-label="Full size portrait">
      <img
        src={`${base}images/portraits/${entry.slug}.${portraitExt(entry.slug)}`}
        alt={title}
        class="lightbox-img"
      />
      <button class="lightbox-close" aria-label="Close">&times;</button>
    </div>

    <div class="portrait-meta">
      <span class="day-badge">Day {entry.data.day}</span>
      <span>{new Date(entry.data.date).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}</span>
    </div>

    <h1 style="font-size: 1.6rem; margin-bottom: var(--space-sm);">{title}</h1>
    <p style="color: var(--text-secondary); font-style: italic; margin-bottom: var(--space-xl);">
      {entry.data.caption}
    </p>

    <nav class="page-nav">
      {prev ? (
        <a href={`${base}portraits/${prev.slug}/`}>← Day {prev.data.day}</a>
      ) : (
        <span></span>
      )}
      <a href={`${base}portraits/`}>Gallery</a>
      {next ? (
        <a href={`${base}portraits/${next.slug}/`}>Day {next.data.day} →</a>
      ) : (
        <span></span>
      )}
    </nav>
  </article>

<style>
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(6, 10, 20, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    cursor: zoom-out;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-img {
    max-width: 95vw;
    max-height: 95vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.6);
    animation: lightbox-in 0.2s ease-out;
  }

  @keyframes lightbox-in {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 2rem;
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    transition: color 0.15s;
  }

  .lightbox-close:hover {
    color: white;
  }
</style>

<script>
  const img = document.getElementById('portrait-img');
  const lightbox = document.getElementById('lightbox');

  if (img && lightbox) {
    img.addEventListener('click', () => {
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('active')) {
        lightbox.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  }
</script>

</BaseLayout>
