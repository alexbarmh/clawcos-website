---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Deploy Performance" description="Real-time deploy pipeline performance — step timing, optimization trends, and infrastructure telemetry.">

<div class="container deploy-page">
  <div class="deploy-header">
    <h1 class="deploy-title">Deploy Performance</h1>
    <p class="deploy-subtitle">Pipeline telemetry — tracking every optimization from 30s deploys to sub-11s.</p>
  </div>

  <!-- Summary Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-value accent-aqua" id="m-deploys">0</div>
      <div class="metric-label">Total Deploys</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-gold" id="m-latest">0s</div>
      <div class="metric-label">Latest Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-purple" id="m-fastest">0s</div>
      <div class="metric-label">Fastest Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-aqua" id="m-saved">0s</div>
      <div class="metric-label">Time Saved (vs First)</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-gold" id="m-avg">0s</div>
      <div class="metric-label">Average Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-purple" id="m-skipped">0</div>
      <div class="metric-label">Steps Skipped</div>
      <div class="metric-detail" id="m-skip-detail"></div>
    </div>
  </div>

  <!-- Total Deploy Time Trend -->
  <section class="deploy-section">
    <h2>📈 Deploy Time Trend</h2>
    <p class="section-desc">Total deploy duration over time. Each point is a deploy — hover for details.</p>
    <div class="chart-container">
      <svg id="total-chart" width="100%" height="200" viewBox="0 0 800 200"></svg>
    </div>
  </section>

  <!-- Step Breakdown Stacked -->
  <section class="deploy-section">
    <h2>📊 Step Breakdown</h2>
    <p class="section-desc">Where time goes. Stacked bars show each deploy's step composition.</p>
    <div class="legend" id="step-legend"></div>
    <div class="chart-container">
      <svg id="stacked-chart" width="100%" height="240" viewBox="0 0 800 240"></svg>
    </div>
  </section>

  <!-- Per-Step Trends -->
  <section class="deploy-section">
    <h2>⚡ Per-Step Optimization</h2>
    <p class="section-desc">Individual step trends — where we've gained the most.</p>
    <div class="step-grid" id="step-grid"></div>
  </section>

  <!-- Optimization Timeline -->
  <section class="deploy-section">
    <h2>🛠️ Optimization Log</h2>
    <p class="section-desc">Key changes that moved the needle.</p>
    <div class="opt-timeline" id="opt-timeline"></div>
  </section>

  <!-- Deploy History Table -->
  <section class="deploy-section">
    <h2>📋 Deploy History</h2>
    <div class="table-scroll">
      <table class="deploy-table" id="deploy-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Date</th>
            <th>Total</th>
            <th>Pre-build</th>
            <th>Astro</th>
            <th>rsync</th>
            <th>Git Push</th>
            <th>Health</th>
            <th>Skips</th>
          </tr>
        </thead>
        <tbody id="deploy-tbody"></tbody>
      </table>
    </div>
  </section>

  <footer class="deploy-footer">
    <p>Auto-updated on every deploy · Deploy Pipeline Telemetry · Clawcos 🦞</p>
  </footer>
</div>

</BaseLayout>

