const DEPLOY_META = {"optimizations":[{"date":"2026-03-28","description":"Baseline deploy pipeline \u2014 sequential rsync, separate SSH connections","impact":"minor","speedup":""},{"date":"2026-03-29","description":"SSH ControlMaster \u2014 single TCP connection for all rsync + ssh calls","impact":"major","speedup":"rsync 10.3s \u2192 2.7s (74%)"},{"date":"2026-03-29","description":"Diff engine content-hash caching \u2014 22x faster","impact":"major","speedup":"0.87s \u2192 0.039s"},{"date":"2026-03-30","description":"rsync no-change detection \u2014 skip zero-change deploys entirely","impact":"major","speedup":"0s when no changes"},{"date":"2026-03-31","description":"Astro build-skip via content-hash \u2014 skip 3.8s build when sources unchanged","impact":"major","speedup":"3.8s \u2192 0.3s (92%)"}],"skip_stats":{"build":0,"sync":0,"total":0}};

// ─── Constants ───────────────────────────────────────────────────────
const STEP_COLORS = {
  "pre-build": "#00d4aa",
  "astro-build": "#f5c542",
  "rsync": "#c084fc",
  "git-push": "#f87171",
  "health-check": "#60a5fa",
};
const STEP_ORDER = ["pre-build", "astro-build", "rsync", "git-push", "health-check"];

// ─── Helpers ─────────────────────────────────────────────────────────
function fmt(ms) {
  if (ms >= 1000) return (ms / 1000).toFixed(1) + "s";
  return ms + "ms";
}

function fmtSec(s) {
  return s + "s";
}

function shortDate(ts) {
  if (!ts) return "?";
  const d = new Date(ts);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

function fullDate(ts) {
  if (!ts) return "?";
  const d = new Date(ts);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
}

// ─── Render Summary Metrics ──────────────────────────────────────────
function renderMetrics() {
  const n = DEPLOY_DATA.length;
  if (n === 0) return;

  const totals = DEPLOY_DATA.map(d => d.total_seconds);
  const latest = totals[n - 1];
  const fastest = Math.min(...totals);
  const saved = totals[0] - latest;
  const avg = (totals.reduce((a, b) => a + b, 0) / n).toFixed(0);

  document.getElementById("m-deploys").textContent = n;
  document.getElementById("m-latest").textContent = fmtSec(latest);
  document.getElementById("m-fastest").textContent = fmtSec(fastest);
  document.getElementById("m-saved").textContent = (saved >= 0 ? "" : "+") + saved + "s";
  document.getElementById("m-avg").textContent = fmtSec(avg);
  const skipStats = DEPLOY_META.skip_stats || { build: 0, sync: 0, total: 0 };
  document.getElementById("m-skipped").textContent = skipStats.total || 0;
  const skipDetail = document.getElementById("m-skip-detail");
  if (skipDetail && (skipStats.build > 0 || skipStats.sync > 0)) {
    const parts = [];
    if (skipStats.build > 0) parts.push(`${skipStats.build} build`);
    if (skipStats.sync > 0) parts.push(`${skipStats.sync} sync`);
    skipDetail.textContent = parts.join(" · ");
  }
}

// ─── Total Deploy Time Line Chart ────────────────────────────────────
function renderTotalChart() {
  const svg = document.getElementById("total-chart");
  if (!svg || DEPLOY_DATA.length < 1) return;

  const W = 800, H = 200, P = 40;
  const data = DEPLOY_DATA;
  const totals = data.map(d => d.total_seconds);
  const minV = Math.min(...totals) - 1;
  const maxV = Math.max(...totals) + 2;
  const range = maxV - minV || 1;

  function toX(i) { return P + (i / Math.max(data.length - 1, 1)) * (W - 2 * P); }
  function toY(v) { return P + (H - 2 * P) - ((v - minV) / range) * (H - 2 * P); }

  // Grid lines
  let html = "";
  const gridSteps = 4;
  for (let i = 0; i <= gridSteps; i++) {
    const v = minV + (range * i / gridSteps);
    const y = toY(v);
    html += `<line x1="${P}" y1="${y}" x2="${W - P}" y2="${y}" stroke="var(--border)" stroke-width="0.5"/>`;
    html += `<text x="${P - 5}" y="${y + 3}" fill="var(--text-dim)" font-size="10" text-anchor="end" font-family="var(--font-sans)">${v.toFixed(0)}s</text>`;
  }

  // Area fill
  const areaPoints = data.map((d, i) => `${toX(i)},${toY(d.total_seconds)}`).join(" ");
  const lastX = toX(data.length - 1);
  const baseY = toY(minV);
  html += `<polygon points="${toX(0)},${baseY} ${areaPoints} ${lastX},${baseY}" fill="url(#areaGrad)" opacity="0.3"/>`;
  html += `<defs><linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--accent-aqua)"/><stop offset="100%" stop-color="transparent"/></linearGradient></defs>`;

  // Line
  const linePoints = data.map((d, i) => `${toX(i)},${toY(d.total_seconds)}`).join(" ");
  html += `<polyline fill="none" stroke="var(--accent-aqua)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="${linePoints}"/>`;

  // Points with tooltips
  data.forEach((d, i) => {
    const x = toX(i);
    const y = toY(d.total_seconds);
    html += `<circle cx="${x}" cy="${y}" r="4" fill="var(--accent-aqua)" stroke="var(--bg)" stroke-width="2" class="deploy-dot">
      <title>${shortDate(d.timestamp)} — ${d.total_seconds}s</title>
    </circle>`;
    // X-axis date labels (sparse)
    if (i === 0 || i === data.length - 1 || i % Math.max(1, Math.floor(data.length / 6)) === 0) {
      html += `<text x="${x}" y="${H - 5}" fill="var(--text-dim)" font-size="9" text-anchor="middle" font-family="var(--font-sans)">${shortDate(d.timestamp)}</text>`;
    }
  });

  svg.innerHTML = html;
}

// ─── Stacked Bar Chart ───────────────────────────────────────────────
function renderStackedChart() {
  const svg = document.getElementById("stacked-chart");
  const legendEl = document.getElementById("step-legend");
  if (!svg || DEPLOY_DATA.length < 1) return;

  const W = 800, H = 240, P = 40;
  const data = DEPLOY_DATA;
  const barW = Math.min(40, (W - 2 * P) / data.length * 0.7);
  const gap = (W - 2 * P - barW * data.length) / Math.max(data.length - 1, 1);

  // Max total ms for scaling
  const maxMs = Math.max(...data.map(d => d.steps.reduce((a, s) => a + s.ms, 0)));
  const chartH = H - 2 * P;

  let html = "";

  // Grid
  for (let i = 0; i <= 4; i++) {
    const v = (maxMs * i / 4);
    const y = P + chartH - (v / maxMs) * chartH;
    html += `<line x1="${P}" y1="${y}" x2="${W - P}" y2="${y}" stroke="var(--border)" stroke-width="0.5"/>`;
    html += `<text x="${P - 5}" y="${y + 3}" fill="var(--text-dim)" font-size="10" text-anchor="end" font-family="var(--font-sans)">${fmt(v)}</text>`;
  }

  data.forEach((d, i) => {
    const x = P + i * (barW + gap);
    let cumY = 0;
    const stepMap = {};
    d.steps.forEach(s => { stepMap[s.name] = s.ms; });

    STEP_ORDER.forEach(step => {
      const ms = stepMap[step] || 0;
      const h = (ms / maxMs) * chartH;
      const y = P + chartH - cumY - h;
      const color = STEP_COLORS[step] || "#888";
      html += `<rect x="${x}" y="${y}" width="${barW}" height="${h}" fill="${color}" rx="1">
        <title>${step}: ${fmt(ms)}</title>
      </rect>`;
      cumY += h;
    });

    // Date label
    if (i === 0 || i === data.length - 1 || i % Math.max(1, Math.floor(data.length / 8)) === 0) {
      html += `<text x="${x + barW / 2}" y="${H - 5}" fill="var(--text-dim)" font-size="9" text-anchor="middle" font-family="var(--font-sans)">${shortDate(d.timestamp)}</text>`;
    }
  });

  svg.innerHTML = html;

  // Legend
  if (legendEl) {
    legendEl.innerHTML = STEP_ORDER.map(step =>
      `<span class="legend-item"><span class="legend-dot" style="background:${STEP_COLORS[step]}"></span>${step}</span>`
    ).join("");
  }
}

// ─── Per-Step Mini Charts ────────────────────────────────────────────
function renderStepGrid() {
  const grid = document.getElementById("step-grid");
  if (!grid || DEPLOY_DATA.length < 2) return;

  grid.innerHTML = STEP_ORDER.map(step => {
    const color = STEP_COLORS[step];
    const vals = DEPLOY_DATA.map(d => {
      const s = d.steps.find(s => s.name === step);
      return s ? s.ms : 0;
    });
    const minV = Math.min(...vals);
    const maxV = Math.max(...vals);
    const range = maxV - minV || 1;
    const first = vals[0];
    const last = vals[vals.length - 1];
    const change = last - first;
    const pct = first > 0 ? Math.abs(change) / first * 100 : 0;
    const dir = change < 0 ? "↓" : change > 0 ? "↑" : "→";
    const dirColor = change < 0 ? "var(--accent-aqua)" : change > 0 ? "#f87171" : "var(--text-dim)";

    // Mini sparkline SVG
    const w = 160, h = 40, p = 4;
    const points = vals.map((v, i) => {
      const x = p + (i / Math.max(vals.length - 1, 1)) * (w - 2 * p);
      const y = p + (h - 2 * p) - ((v - minV) / range) * (h - 2 * p);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    }).join(" ");

    return `<div class="step-card">
      <div class="step-card-header">
        <span class="step-name" style="color:${color}">${step}</span>
        <span class="step-trend" style="color:${dirColor}">${dir} ${pct.toFixed(0)}%</span>
      </div>
      <svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">
        <polyline fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="${points}"/>
      </svg>
      <div class="step-card-footer">
        <span>${fmt(first)}</span>
        <span>→</span>
        <span>${fmt(last)}</span>
      </div>
    </div>`;
  }).join("");
}

// ─── Optimization Timeline ───────────────────────────────────────────
function renderOptTimeline() {
  const container = document.getElementById("opt-timeline");
  if (!container) return;

  const opts = DEPLOY_META.optimizations || [];
  if (opts.length === 0) {
    container.innerHTML = `<p class="section-desc">No optimization events logged yet.</p>`;
    return;
  }

  container.innerHTML = opts.map(o => `
    <div class="opt-entry">
      <span class="opt-date">${shortDate(o.date)}</span>
      <span class="opt-badge ${o.impact}">${o.impact}</span>
      <span class="opt-desc">${o.description}</span>
      ${o.speedup ? `<span class="opt-speedup">${o.speedup}</span>` : ""}
    </div>
  `).join("");
}

// ─── Deploy History Table ────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById("deploy-tbody");
  if (!tbody) return;

  tbody.innerHTML = DEPLOY_DATA.slice().reverse().map((d, idx) => {
    const num = DEPLOY_DATA.length - idx;
    const stepMap = {};
    d.steps.forEach(s => { stepMap[s.name] = s.ms; });

    const skips = [];
    if (d.build_skipped) skips.push("build");
    if (d.sync_skipped) skips.push("sync");
    const skipCell = skips.length > 0
      ? `<span class="skip-badge">${skips.join(", ")}</span>`
      : '<span class="no-skip">—</span>';

    return `<tr>
      <td class="td-num">${num}</td>
      <td>${fullDate(d.timestamp)}</td>
      <td class="td-total">${d.total_seconds}s</td>
      <td>${fmt(stepMap["pre-build"] || 0)}</td>
      <td>${fmt(stepMap["astro-build"] || 0)}</td>
      <td>${fmt(stepMap["rsync"] || 0)}</td>
      <td>${fmt(stepMap["git-push"] || 0)}</td>
      <td>${fmt(stepMap["health-check"] || 0)}</td>
      <td>${skipCell}</td>
    </tr>`;
  }).join("");
}

// ─── Init ────────────────────────────────────────────────────────────
renderMetrics();
renderTotalChart();
renderStackedChart();
renderStepGrid();
renderOptTimeline();
renderTable();
</script>

