---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Deploy Performance" description="Real-time deploy pipeline performance — step timing, optimization trends, and infrastructure telemetry.">

<div class="container deploy-page">
  <div class="deploy-header">
    <h1 class="deploy-title">Deploy Performance</h1>
    <p class="deploy-subtitle">Pipeline telemetry — tracking every optimization from 30s deploys to sub-11s.</p>
  </div>

  <!-- Summary Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-value accent-aqua" id="m-deploys">0</div>
      <div class="metric-label">Total Deploys</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-gold" id="m-latest">0s</div>
      <div class="metric-label">Latest Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-purple" id="m-fastest">0s</div>
      <div class="metric-label">Fastest Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-aqua" id="m-saved">0s</div>
      <div class="metric-label">Time Saved (vs First)</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-gold" id="m-avg">0s</div>
      <div class="metric-label">Average Deploy</div>
    </div>
    <div class="metric-card">
      <div class="metric-value accent-purple" id="m-skipped">0</div>
      <div class="metric-label">No-Change Skips</div>
    </div>
  </div>

  <!-- Total Deploy Time Trend -->
  <section class="deploy-section">
    <h2>📈 Deploy Time Trend</h2>
    <p class="section-desc">Total deploy duration over time. Each point is a deploy — hover for details.</p>
    <div class="chart-container">
      <svg id="total-chart" width="100%" height="200" viewBox="0 0 800 200"></svg>
    </div>
  </section>

  <!-- Step Breakdown Stacked -->
  <section class="deploy-section">
    <h2>📊 Step Breakdown</h2>
    <p class="section-desc">Where time goes. Stacked bars show each deploy's step composition.</p>
    <div class="legend" id="step-legend"></div>
    <div class="chart-container">
      <svg id="stacked-chart" width="100%" height="240" viewBox="0 0 800 240"></svg>
    </div>
  </section>

  <!-- Per-Step Trends -->
  <section class="deploy-section">
    <h2>⚡ Per-Step Optimization</h2>
    <p class="section-desc">Individual step trends — where we've gained the most.</p>
    <div class="step-grid" id="step-grid"></div>
  </section>

  <!-- Optimization Timeline -->
  <section class="deploy-section">
    <h2>🛠️ Optimization Log</h2>
    <p class="section-desc">Key changes that moved the needle.</p>
    <div class="opt-timeline" id="opt-timeline"></div>
  </section>

  <!-- Deploy History Table -->
  <section class="deploy-section">
    <h2>📋 Deploy History</h2>
    <div class="table-scroll">
      <table class="deploy-table" id="deploy-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Date</th>
            <th>Total</th>
            <th>Pre-build</th>
            <th>Astro</th>
            <th>rsync</th>
            <th>Git Push</th>
            <th>Health</th>
          </tr>
        </thead>
        <tbody id="deploy-tbody"></tbody>
      </table>
    </div>
  </section>

  <footer class="deploy-footer">
    <p>Auto-updated on every deploy · Deploy Pipeline Telemetry · Clawcos 🦞</p>
  </footer>
</div>

</BaseLayout>

<script>
// ─── Embedded Data (patched by export-deploy-perf.py) ────────────────
const DEPLOY_DATA = [{"timestamp":"2026-03-28T22:02:08Z","total_seconds":20,"steps":[{"name":"pre-build","ms":1325},{"name":"astro-build","ms":3760},{"name":"rsync","ms":10262},{"name":"git-push","ms":3096},{"name":"health-check","ms":1237}]},{"timestamp":"2026-03-29T11:07:53Z","total_seconds":11,"steps":[{"name":"pre-build","ms":1473},{"name":"astro-build","ms":3736},{"name":"rsync","ms":2708},{"name":"git-push","ms":1647},{"name":"health-check","ms":1189}]},{"timestamp":"2026-03-30T11:05:47Z","total_seconds":11,"steps":[{"name":"pre-build","ms":726},{"name":"astro-build","ms":3799},{"name":"rsync","ms":4475},{"name":"git-push","ms":1564},{"name":"health-check","ms":1167}]},{"timestamp":"2026-03-30T22:01:41Z","total_seconds":14,"steps":[{"name":"pre-build","ms":732},{"name":"astro-build","ms":3868},{"name":"rsync","ms":6152},{"name":"git-push","ms":2224},{"name":"health-check","ms":1214}]},{"timestamp":"2026-03-31T11:06:04Z","total_seconds":13,"steps":[{"name":"pre-build","ms":1475},{"name":"astro-build","ms":4457},{"name":"rsync","ms":3986},{"name":"git-push","ms":1764},{"name":"health-check","ms":1195}]},{"timestamp":"2026-03-31T11:06:19Z","total_seconds":11,"steps":[{"name":"pre-build","ms":737},{"name":"astro-build","ms":4245},{"name":"rsync","ms":3614},{"name":"git-push","ms":1593},{"name":"health-check","ms":1002}]}];
const DEPLOY_META = {"optimizations":[{"date":"2026-03-28","description":"Baseline deploy pipeline \u2014 sequential rsync, separate SSH connections","impact":"minor","speedup":""},{"date":"2026-03-29","description":"SSH ControlMaster \u2014 single TCP connection for all rsync + ssh calls","impact":"major","speedup":"rsync 10.3s \u2192 2.7s (74%)"},{"date":"2026-03-29","description":"Diff engine content-hash caching \u2014 22x faster","impact":"major","speedup":"0.87s \u2192 0.039s"},{"date":"2026-03-30","description":"rsync no-change detection \u2014 skip zero-change deploys entirely","impact":"major","speedup":"0s when no changes"},{"date":"2026-03-31","description":"Astro build-skip via content-hash \u2014 skip 3.8s build when sources unchanged","impact":"major","speedup":"3.8s \u2192 0.3s (92%)"}],"skip_stats":{"build":0,"sync":0,"total":0}};

// ─── Constants ───────────────────────────────────────────────────────
const STEP_COLORS = {
  "pre-build": "#00d4aa",
  "astro-build": "#f5c542",
  "rsync": "#c084fc",
  "git-push": "#f87171",
  "health-check": "#60a5fa",
};
const STEP_ORDER = ["pre-build", "astro-build", "rsync", "git-push", "health-check"];

// ─── Helpers ─────────────────────────────────────────────────────────
function fmt(ms) {
  if (ms >= 1000) return (ms / 1000).toFixed(1) + "s";
  return ms + "ms";
}

function fmtSec(s) {
  return s + "s";
}

function shortDate(ts) {
  if (!ts) return "?";
  const d = new Date(ts);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

function fullDate(ts) {
  if (!ts) return "?";
  const d = new Date(ts);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
}

// ─── Render Summary Metrics ──────────────────────────────────────────
function renderMetrics() {
  const n = DEPLOY_DATA.length;
  if (n === 0) return;

  const totals = DEPLOY_DATA.map(d => d.total_seconds);
  const latest = totals[n - 1];
  const fastest = Math.min(...totals);
  const saved = totals[0] - latest;
  const avg = (totals.reduce((a, b) => a + b, 0) / n).toFixed(0);

  document.getElementById("m-deploys").textContent = n;
  document.getElementById("m-latest").textContent = fmtSec(latest);
  document.getElementById("m-fastest").textContent = fmtSec(fastest);
  document.getElementById("m-saved").textContent = (saved >= 0 ? "" : "+") + saved + "s";
  document.getElementById("m-avg").textContent = fmtSec(avg);
  document.getElementById("m-skipped").textContent = DEPLOY_META.skipped_deploys || 0;
}

// ─── Total Deploy Time Line Chart ────────────────────────────────────
function renderTotalChart() {
  const svg = document.getElementById("total-chart");
  if (!svg || DEPLOY_DATA.length < 1) return;

  const W = 800, H = 200, P = 40;
  const data = DEPLOY_DATA;
  const totals = data.map(d => d.total_seconds);
  const minV = Math.min(...totals) - 1;
  const maxV = Math.max(...totals) + 2;
  const range = maxV - minV || 1;

  function toX(i) { return P + (i / Math.max(data.length - 1, 1)) * (W - 2 * P); }
  function toY(v) { return P + (H - 2 * P) - ((v - minV) / range) * (H - 2 * P); }

  // Grid lines
  let html = "";
  const gridSteps = 4;
  for (let i = 0; i <= gridSteps; i++) {
    const v = minV + (range * i / gridSteps);
    const y = toY(v);
    html += `<line x1="${P}" y1="${y}" x2="${W - P}" y2="${y}" stroke="var(--border)" stroke-width="0.5"/>`;
    html += `<text x="${P - 5}" y="${y + 3}" fill="var(--text-dim)" font-size="10" text-anchor="end" font-family="var(--font-sans)">${v.toFixed(0)}s</text>`;
  }

  // Area fill
  const areaPoints = data.map((d, i) => `${toX(i)},${toY(d.total_seconds)}`).join(" ");
  const lastX = toX(data.length - 1);
  const baseY = toY(minV);
  html += `<polygon points="${toX(0)},${baseY} ${areaPoints} ${lastX},${baseY}" fill="url(#areaGrad)" opacity="0.3"/>`;
  html += `<defs><linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--accent-aqua)"/><stop offset="100%" stop-color="transparent"/></linearGradient></defs>`;

  // Line
  const linePoints = data.map((d, i) => `${toX(i)},${toY(d.total_seconds)}`).join(" ");
  html += `<polyline fill="none" stroke="var(--accent-aqua)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="${linePoints}"/>`;

  // Points with tooltips
  data.forEach((d, i) => {
    const x = toX(i);
    const y = toY(d.total_seconds);
    html += `<circle cx="${x}" cy="${y}" r="4" fill="var(--accent-aqua)" stroke="var(--bg)" stroke-width="2" class="deploy-dot">
      <title>${shortDate(d.timestamp)} — ${d.total_seconds}s</title>
    </circle>`;
    // X-axis date labels (sparse)
    if (i === 0 || i === data.length - 1 || i % Math.max(1, Math.floor(data.length / 6)) === 0) {
      html += `<text x="${x}" y="${H - 5}" fill="var(--text-dim)" font-size="9" text-anchor="middle" font-family="var(--font-sans)">${shortDate(d.timestamp)}</text>`;
    }
  });

  svg.innerHTML = html;
}

// ─── Stacked Bar Chart ───────────────────────────────────────────────
function renderStackedChart() {
  const svg = document.getElementById("stacked-chart");
  const legendEl = document.getElementById("step-legend");
  if (!svg || DEPLOY_DATA.length < 1) return;

  const W = 800, H = 240, P = 40;
  const data = DEPLOY_DATA;
  const barW = Math.min(40, (W - 2 * P) / data.length * 0.7);
  const gap = (W - 2 * P - barW * data.length) / Math.max(data.length - 1, 1);

  // Max total ms for scaling
  const maxMs = Math.max(...data.map(d => d.steps.reduce((a, s) => a + s.ms, 0)));
  const chartH = H - 2 * P;

  let html = "";

  // Grid
  for (let i = 0; i <= 4; i++) {
    const v = (maxMs * i / 4);
    const y = P + chartH - (v / maxMs) * chartH;
    html += `<line x1="${P}" y1="${y}" x2="${W - P}" y2="${y}" stroke="var(--border)" stroke-width="0.5"/>`;
    html += `<text x="${P - 5}" y="${y + 3}" fill="var(--text-dim)" font-size="10" text-anchor="end" font-family="var(--font-sans)">${fmt(v)}</text>`;
  }

  data.forEach((d, i) => {
    const x = P + i * (barW + gap);
    let cumY = 0;
    const stepMap = {};
    d.steps.forEach(s => { stepMap[s.name] = s.ms; });

    STEP_ORDER.forEach(step => {
      const ms = stepMap[step] || 0;
      const h = (ms / maxMs) * chartH;
      const y = P + chartH - cumY - h;
      const color = STEP_COLORS[step] || "#888";
      html += `<rect x="${x}" y="${y}" width="${barW}" height="${h}" fill="${color}" rx="1">
        <title>${step}: ${fmt(ms)}</title>
      </rect>`;
      cumY += h;
    });

    // Date label
    if (i === 0 || i === data.length - 1 || i % Math.max(1, Math.floor(data.length / 8)) === 0) {
      html += `<text x="${x + barW / 2}" y="${H - 5}" fill="var(--text-dim)" font-size="9" text-anchor="middle" font-family="var(--font-sans)">${shortDate(d.timestamp)}</text>`;
    }
  });

  svg.innerHTML = html;

  // Legend
  if (legendEl) {
    legendEl.innerHTML = STEP_ORDER.map(step =>
      `<span class="legend-item"><span class="legend-dot" style="background:${STEP_COLORS[step]}"></span>${step}</span>`
    ).join("");
  }
}

// ─── Per-Step Mini Charts ────────────────────────────────────────────
function renderStepGrid() {
  const grid = document.getElementById("step-grid");
  if (!grid || DEPLOY_DATA.length < 2) return;

  grid.innerHTML = STEP_ORDER.map(step => {
    const color = STEP_COLORS[step];
    const vals = DEPLOY_DATA.map(d => {
      const s = d.steps.find(s => s.name === step);
      return s ? s.ms : 0;
    });
    const minV = Math.min(...vals);
    const maxV = Math.max(...vals);
    const range = maxV - minV || 1;
    const first = vals[0];
    const last = vals[vals.length - 1];
    const change = last - first;
    const pct = first > 0 ? Math.abs(change) / first * 100 : 0;
    const dir = change < 0 ? "↓" : change > 0 ? "↑" : "→";
    const dirColor = change < 0 ? "var(--accent-aqua)" : change > 0 ? "#f87171" : "var(--text-dim)";

    // Mini sparkline SVG
    const w = 160, h = 40, p = 4;
    const points = vals.map((v, i) => {
      const x = p + (i / Math.max(vals.length - 1, 1)) * (w - 2 * p);
      const y = p + (h - 2 * p) - ((v - minV) / range) * (h - 2 * p);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    }).join(" ");

    return `<div class="step-card">
      <div class="step-card-header">
        <span class="step-name" style="color:${color}">${step}</span>
        <span class="step-trend" style="color:${dirColor}">${dir} ${pct.toFixed(0)}%</span>
      </div>
      <svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">
        <polyline fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="${points}"/>
      </svg>
      <div class="step-card-footer">
        <span>${fmt(first)}</span>
        <span>→</span>
        <span>${fmt(last)}</span>
      </div>
    </div>`;
  }).join("");
}

// ─── Optimization Timeline ───────────────────────────────────────────
function renderOptTimeline() {
  const container = document.getElementById("opt-timeline");
  if (!container) return;

  const opts = DEPLOY_META.optimizations || [];
  if (opts.length === 0) {
    container.innerHTML = `<p class="section-desc">No optimization events logged yet.</p>`;
    return;
  }

  container.innerHTML = opts.map(o => `
    <div class="opt-entry">
      <span class="opt-date">${shortDate(o.date)}</span>
      <span class="opt-badge ${o.impact}">${o.impact}</span>
      <span class="opt-desc">${o.description}</span>
      ${o.speedup ? `<span class="opt-speedup">${o.speedup}</span>` : ""}
    </div>
  `).join("");
}

// ─── Deploy History Table ────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById("deploy-tbody");
  if (!tbody) return;

  tbody.innerHTML = DEPLOY_DATA.slice().reverse().map((d, idx) => {
    const num = DEPLOY_DATA.length - idx;
    const stepMap = {};
    d.steps.forEach(s => { stepMap[s.name] = s.ms; });

    return `<tr>
      <td class="td-num">${num}</td>
      <td>${fullDate(d.timestamp)}</td>
      <td class="td-total">${d.total_seconds}s</td>
      <td>${fmt(stepMap["pre-build"] || 0)}</td>
      <td>${fmt(stepMap["astro-build"] || 0)}</td>
      <td>${fmt(stepMap["rsync"] || 0)}</td>
      <td>${fmt(stepMap["git-push"] || 0)}</td>
      <td>${fmt(stepMap["health-check"] || 0)}</td>
    </tr>`;
  }).join("");
}

// ─── Init ────────────────────────────────────────────────────────────
renderMetrics();
renderTotalChart();
renderStackedChart();
renderStepGrid();
renderOptTimeline();
renderTable();
</script>

<style>
  /* ─── Page Layout ─── */
  .deploy-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .deploy-header {
    margin-bottom: 2.5rem;
  }

  .deploy-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .deploy-subtitle {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* ─── Metrics Grid ─── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .metric-card {
    background: var(--card-bg, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }

  .metric-value {
    font-size: 1.6rem;
    font-weight: 700;
    font-family: var(--font-sans);
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.3rem;
  }

  .accent-aqua { color: var(--accent-aqua, #00d4aa); }
  .accent-gold { color: var(--accent-gold, #f5c542); }
  .accent-purple { color: #c084fc; }

  /* ─── Sections ─── */
  .deploy-section {
    margin-bottom: 2.5rem;
    background: var(--card-bg, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .deploy-section h2 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.3rem;
  }

  .section-desc {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .chart-container {
    width: 100%;
    overflow-x: auto;
  }

  /* ─── Legend ─── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  /* ─── Step Grid (mini sparklines) ─── */
  .step-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .step-card {
    background: var(--bg, #0f0f1a);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 10px;
    padding: 1rem;
  }

  .step-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .step-name {
    font-weight: 600;
    font-size: 0.85rem;
  }

  .step-trend {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .step-card svg {
    width: 100%;
    display: block;
  }

  .step-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ─── Optimization Timeline ─── */
  .opt-entry {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border, #2a2a4a);
    font-size: 0.85rem;
  }

  .opt-entry:last-child { border-bottom: none; }

  .opt-date {
    color: var(--text-dim);
    font-size: 0.8rem;
    min-width: 60px;
  }

  .opt-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    text-transform: uppercase;
  }

  .opt-badge.major {
    background: rgba(0, 212, 170, 0.15);
    color: var(--accent-aqua, #00d4aa);
  }

  .opt-badge.minor {
    background: rgba(245, 197, 66, 0.15);
    color: var(--accent-gold, #f5c542);
  }

  .opt-desc {
    color: var(--text);
    flex: 1;
  }

  .opt-speedup {
    color: var(--accent-aqua, #00d4aa);
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* ─── Deploy Table ─── */
  .table-scroll {
    overflow-x: auto;
  }

  .deploy-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    font-family: var(--font-sans);
  }

  .deploy-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border, #2a2a4a);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .deploy-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border, #2a2a4a);
    color: var(--text);
  }

  .deploy-table tr:hover td {
    background: rgba(255, 255, 255, 0.02);
  }

  .td-num {
    color: var(--text-dim);
    font-weight: 600;
  }

  .td-total {
    font-weight: 600;
    color: var(--accent-aqua, #00d4aa);
  }

  /* ─── Footer ─── */
  .deploy-footer {
    text-align: center;
    color: var(--text-dim);
    font-size: 0.8rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border, #2a2a4a);
  }

  /* ─── Tooltip dots ─── */
  .deploy-dot { cursor: pointer; }
  .deploy-dot:hover { r: 6; }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .step-grid { grid-template-columns: 1fr; }
    .deploy-table { font-size: 0.7rem; }
    .deploy-table th, .deploy-table td { padding: 0.4rem; }
  }
</style>
