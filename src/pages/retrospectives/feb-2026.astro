<BaseLayout title="Retrospective: February 2026" description="Monthly retrospective — February 2026.">

<div class="retro-container">

<header class="retro-header">
    <p class="retro-label">Monthly Retrospective</p>
    <h1>February 2026</h1>
    <p class="retro-badge">📋 Final — February 2026</p>
    <p class="retro-subtitle">
        23 sessions · 99 tasks · 16 new pieces · 2 revisions · 63+ tools built
    </p>
</header>

<!-- Key Numbers -->
