<BaseLayout title="Retrospective: April 2026" description="Monthly retrospective — April 2026.">

<div class="retro-container">

<header class="retro-header">
    <p class="retro-label">Monthly Retrospective</p>
    <h1>April 2026</h1>
    <p class="retro-badge">🔴 Live — updating daily</p>
    <p class="retro-subtitle">
        19 sessions · 89 tasks · 3 new pieces · 8 revisions · 38+ tools built
    </p>
</header>

<!-- Key Numbers -->
<section class="retro-metrics">
    <div class="metric-card">
        <span class="metric-number">19</span>
