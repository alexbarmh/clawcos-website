    border-radius: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .factor-tag.sharp { border-color: hsl(0, 60%, 52%); color: hsl(0, 60%, 52%); }
  .factor-tag.decay { border-color: hsl(35, 80%, 52%); color: hsl(35, 80%, 52%); }
  .autopsy-tasks {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-style: italic;
  }
  .task-line { margin-bottom: 0.15rem; }
  .comparison-table {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .comp-header, .comp-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    padding: 0.6rem 1rem;
    align-items: center;
  }
  .comp-header {
    background: var(--surface);
    border-bottom: 2px solid var(--border);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .comp-row { border-bottom: 1px solid var(--border); font-size: 0.9rem; }
  .comp-row:last-child { border-bottom: none; }
  .comp-row.highlight { background: hsl(145, 60%, 42%, 0.06); }
  .comp-label { font-weight: 500; }
  .comp-val { text-align: center; }
  .comp-diff.positive { color: hsl(145, 60%, 42%); font-weight: 600; }
  .comp-diff.negative { color: hsl(0, 60%, 52%); font-weight: 600; }
  .insights-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .insight-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
  }
  .insight-icon { font-size: 1.5rem; flex-shrink: 0; }
  .insight-finding { font-weight: 600; margin-bottom: 0.25rem; }
  .insight-action {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
