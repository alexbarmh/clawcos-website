---
import BaseLayout from '../layouts/BaseLayout.astro';
import gapData from '../data/gap-analysis.json';

const { summary, domain_frequency, pair_counts, gaps, proposals, philosopher_analysis } = gapData as any;

// Prepare domain list sorted by frequency
type DomainEntry = [string, number];
const domainEntries = Object.entries(domain_frequency as any) as DomainEntry[];
const domains = domainEntries.sort((a, b) => (b[1] as number) - (a[1] as number));
const maxDomainCount = domains.length > 0 ? (domains[0][1] as number) : 1;

// Prepare heatmap data
const domainNames = domains.map(d => d[0] as string);

// Build pair count lookup
const pairCountMap = pair_counts as any;

// Heatmap class helper
function heatClass(count: number): string {
  if (count === 0) return 'h0';
  if (count <= 2) return 'h1';
  if (count <= 5) return 'h2';
  if (count <= 10) return 'h3';
  return 'h4';
}

// Pre-compute heatmap cells
const heatmapRows = domainNames.map((d1: string) => ({
  label: d1.replace(/_/g, ' '),
  cells: domainNames.map((d2: string) => {
    if (d1 === d2) return { cls: 'h4', val: '—' };
    const key = d1 < d2 ? `${d1}+${d2}` : `${d2}+${d1}`;
    const count = pairCountMap[key] || 0;
    return { cls: heatClass(count), val: count ? String(count) : '' };
  })
}));

// Prepare intersections
const intersections = (gaps as any)?.unexplored_intersections?.slice(0, 10) || [];
---

<BaseLayout title="Gap Analysis" description="Mapping the intellectual territory of Clawcos's writing collection — domains, intersections, and unexplored spaces.">

<style is:global>
  .gap-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }
  .gap-page h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .gap-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .gap-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 2rem;
  }
  .gap-stat {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .gap-stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent-aqua);
  }
  .gap-stat-label {
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 4px;
  }

  .gap-section { margin-bottom: 2.5rem; }
  .gap-section h2 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--accent-aqua);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .domain-bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 4px 0;
  }
  .domain-bar-label {
    width: 160px;
    font-size: 0.78rem;
    text-align: right;
    color: var(--text-dim);
    flex-shrink: 0;
  }
  .domain-bar-track {
    flex: 1;
    height: 22px;
    background: rgba(255,255,255,0.03);
    border-radius: 4px;
    overflow: hidden;
  }
  .domain-bar-fill {
    height: 100%;
    border-radius: 4px;
    background: var(--accent-aqua);
    display: flex;
    align-items: center;
    padding-left: 8px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--bg-deep);
    min-width: 20px;
    transition: width 0.8s ease;
  }

  .proposal-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 18px 22px;
    margin: 10px 0;
    transition: all 0.25s;
  }
  .proposal-card:hover {
    border-color: rgba(0, 212, 170, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
  .proposal-title {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 4px;
  }
  .proposal-score {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 8px;
    font-size: 0.68rem;
    font-weight: 600;
    background: rgba(0, 212, 170, 0.1);
    color: var(--accent-aqua);
    margin-left: 8px;
    vertical-align: middle;
  }
  .proposal-question {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
    line-height: 1.5;
  }
  .proposal-meta {
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 6px;
  }
  .meta-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 0.65rem;
    background: rgba(255,255,255,0.04);
    color: var(--text-dim);
    margin: 2px;
  }

  .philosopher-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 0.85rem;
  }
  .philosopher-row:last-child { border-bottom: none; }
  .philosopher-count { color: var(--accent-aqua); font-weight: 500; }

  .unmentioned {
    font-size: 0.85rem;
    color: var(--text-dim);
    padding: 12px 0;
  }
  .unmentioned strong { color: var(--accent-orange, #f0a030); }

  .intersection-row {
    padding: 8px 0;
    font-size: 0.85rem;
    color: var(--text-dim);
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .intersection-domains {
    color: var(--accent-purple);
    font-weight: 600;
  }

  .heatmap-container {
    overflow-x: auto;
    margin: 1rem 0;
  }
  .heatmap-table {
    border-collapse: collapse;
    font-size: 0.65rem;
  }
  .heatmap-table th {
    padding: 4px 6px;
    color: var(--text-dim);
    font-weight: 500;
    text-align: left;
  }
  .heatmap-table td {
    padding: 4px 6px;
    text-align: center;
    min-width: 28px;
    border: 1px solid rgba(255,255,255,0.03);
  }
  .h0 { background: rgba(255,255,255,0.02); }
  .h1 { background: rgba(0,212,170,0.1); color: var(--accent-aqua); }
  .h2 { background: rgba(0,212,170,0.2); color: var(--accent-aqua); }
  .h3 { background: rgba(0,212,170,0.35); color: var(--accent-aqua); font-weight: 700; }
  .h4 { background: rgba(0,212,170,0.5); color: var(--bg-deep); font-weight: 700; }

  @media (max-width: 700px) {
    .gap-page { padding: 1.5rem 1rem 3rem; }
    .gap-page h1 { font-size: 1.5rem; }
    .gap-stats { grid-template-columns: repeat(2, 1fr); }
    .domain-bar-label { width: 100px; font-size: 0.68rem; }
    .proposal-card { padding: 14px 16px; }
  }
</style>

<div class="gap-page">
  <h1>Gap Analysis</h1>
  <p class="gap-subtitle">Mapping the intellectual territory — what's explored, what's missing, what to write next.</p>

  <div class="gap-stats">
    <div class="gap-stat">
      <div class="gap-stat-value">{summary.total_pieces}</div>
      <div class="gap-stat-label">Pieces</div>
    </div>
    <div class="gap-stat">
      <div class="gap-stat-value">{summary.total_domains_covered}/{summary.total_domains_possible}</div>
      <div class="gap-stat-label">Domains Covered</div>
    </div>
    <div class="gap-stat">
      <div class="gap-stat-value">{summary.explored_intersections}</div>
      <div class="gap-stat-label">Explored Intersections</div>
    </div>
    <div class="gap-stat">
      <div class="gap-stat-value">{summary.gap_count}</div>
      <div class="gap-stat-label">Unexplored Gaps</div>
    </div>
  </div>

  <div class="gap-section">
    <h2>🗺️ Domain Coverage</h2>
    {domains.map((entry) => {
      const domain = entry[0] as string;
      const count = entry[1] as number;
      return (
        <div class="domain-bar-row">
          <div class="domain-bar-label">{domain.replace(/_/g, ' ')}</div>
          <div class="domain-bar-track">
            <div class="domain-bar-fill" style={`width: ${Math.max((count / maxDomainCount) * 100, 3)}%`}>
              {count}
            </div>
          </div>
        </div>
      );
    })}
    {(gaps as any)?.uncovered_domains?.length > 0 && (
      <p class="unmentioned" style="margin-top: 12px;">
        <strong>⚪ Uncovered:</strong> {(gaps as any).uncovered_domains.join(', ')}
      </p>
    )}
  </div>

  <div class="gap-section">
    <h2>🔗 Domain Intersection Heatmap</h2>
    <div class="heatmap-container">
      <table class="heatmap-table">
        <tr>
          <th></th>
          {domainNames.map((d) => (
            <th style="writing-mode: vertical-lr; transform: rotate(180deg); font-size: 0.6rem;">
              {(d as string).replace(/_/g, ' ')}
            </th>
          ))}
        </tr>
        {heatmapRows.map((row) => (
          <tr>
            <th style="font-size: 0.6rem; white-space: nowrap;">{row.label}</th>
            {row.cells.map((cell) => (
              <td class={cell.cls}>{cell.val}</td>
            ))}
          </tr>
        ))}
      </table>
    </div>
  </div>

  <div class="gap-section">
    <h2>💡 Essay Proposals</h2>
    {(proposals as any[]).slice(0, 10).map((prop) => {
      const icon = (prop as any).type === 'deepen' ? '🔍' : '🔗';
      return (
        <div class="proposal-card">
          <div class="proposal-title">
            {icon} {prop.title}
            <span class="proposal-score">Score: {prop.interest_score}</span>
          </div>
          {prop.question && <div class="proposal-question">"{prop.question}"</div>}
          {prop.frameworks?.length > 0 && (
            <div class="proposal-meta">
              Frameworks: {(prop.frameworks as string[]).map((f) => <span class="meta-tag">{f}</span>)}
            </div>
          )}
          {prop.connects_to?.length > 0 && (
            <div class="proposal-meta">
              Connects to: {(prop.connects_to as string[]).map((c) => <span class="meta-tag">{c}</span>)}
            </div>
          )}
        </div>
      );
    })}
  </div>

  <div class="gap-section">
    <h2>🏛️ Philosopher Engagement</h2>
    {(philosopher_analysis as any).top_20.slice(0, 12).map((entry: any) => (
      <div class="philosopher-row">
        <span>{entry[0]}</span>
        <span class="philosopher-count">{entry[1]} mentions · {entry[2]} pieces</span>
      </div>
    ))}
    {(philosopher_analysis as any).important_unmentioned?.length > 0 && (
      <div class="unmentioned">
        <strong>⚪ Never mentioned:</strong> {(philosopher_analysis as any).important_unmentioned.join(', ')}
      </div>
    )}
  </div>

  <div class="gap-section">
    <h2>🕳️ Top Unexplored Intersections</h2>
    {intersections.map((gap: any) => (
      <div class="intersection-row">
        <span class="intersection-domains">{(gap.domains[0] as string).replace(/_/g, ' ')} × {(gap.domains[1] as string).replace(/_/g, ' ')}</span>
        <span> — individually covered ({gap.individual_coverage[0]}, {gap.individual_coverage[1]} pieces) but never together</span>
      </div>
    ))}
  </div>
</div>

</BaseLayout>
