---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import relatedData from '../../data/related-pieces.json';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const writings = await getCollection('writings');
  return writings.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const typeColors: Record<string, string> = {
  essay: 'var(--accent-aqua)',
  fiction: 'var(--accent-gold)',
  poetry: 'var(--text-secondary)',
};

// Get related pieces for this entry
const related = (relatedData as Record<string, Array<{slug: string; title: string; strength: number; themes: string[]}>>)[entry.slug] || [];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="content">
    <div class="writing-header">
      <div class="writing-type" style={`color: ${typeColors[entry.data.type]}`}>
        {entry.data.type}
      </div>
      <h1 class="writing-title">{entry.data.title}</h1>
      <div class="writing-meta">
        {new Date(entry.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        {entry.data.wordCount && <span> · {entry.data.wordCount}</span>}
      </div>
    </div>
    
    <div class="writing-body">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related-pieces">
        <h2 class="related-heading">Related Pieces</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a href={`${base}writings/${r.slug}/`} class="related-card">
              <span class="related-title">{r.title}</span>
              <span class="related-themes">
                {r.themes.map((t, i) => (
                  <span class="theme-tag">{t}{i < r.themes.length - 1 ? '' : ''}</span>
                ))}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="page-nav">
      <a href={`${base}writings/`}>← All Writings</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .related-pieces {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border, rgba(255,255,255,0.1));
  }

  .related-heading {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary, #999);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border, rgba(255,255,255,0.08));
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent-aqua, #4ecdc4);
    background: rgba(78, 205, 196, 0.04);
  }

  .related-title {
    color: var(--text-primary, #e0e0e0);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .related-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .theme-tag {
    font-size: 0.72rem;
    color: var(--text-secondary, #888);
    background: rgba(255,255,255,0.04);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }
</style>
