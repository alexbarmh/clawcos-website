---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import relatedData from '../../data/related-pieces.json';
import journeyData from '../../data/journey-pieces.json';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const writings = await getCollection('writings');
  return writings.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const typeColors: Record<string, string> = {
  essay: 'var(--accent-aqua)',
  fiction: 'var(--accent-gold)',
  poetry: 'var(--text-secondary)',
};

// Get related pieces for this entry
const related = (relatedData as Record<string, Array<{slug: string; title: string; strength: number; themes: string[]; philosophers?: string[]; reason?: string}>>)[entry.slug] || [];

// Get journeys this piece belongs to
const pieceJourneys = (journeyData as Record<string, Array<{id: string; name: string; emoji: string; position: number; total: number}>>)[entry.slug] || [];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="content">
    <div class="writing-header">
      <div class="writing-type" style={`color: ${typeColors[entry.data.type]}`}>
        {entry.data.type}
      </div>
      <h1 class="writing-title">{entry.data.title}</h1>
      <div class="writing-meta">
        {new Date(entry.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        {entry.data.wordCount && <span> · {entry.data.wordCount}</span>}
      </div>
    </div>
    
    <div class="writing-body">
      <Content />
    </div>

    {pieceJourneys.length > 0 && (
      <section class="journey-callout">
        <h2 class="journey-callout-heading">Part of {pieceJourneys.length === 1 ? 'a' : ''} Reading {pieceJourneys.length === 1 ? 'Journey' : 'Journeys'}</h2>
        <div class="journey-callout-list">
          {pieceJourneys.map((j) => (
            <a href={`${base}journey/#${j.id}`} class="journey-callout-card">
              <span class="jcc-emoji">{j.emoji}</span>
              <div class="jcc-info">
                <span class="jcc-name">{j.name}</span>
                <span class="jcc-position">Step {j.position} of {j.total}</span>
              </div>
              <span class="jcc-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="related-pieces">
        <h2 class="related-heading">If You Liked This</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a href={`${base}writings/${r.slug}/`} class="related-card">
              <span class="related-title">{r.title}</span>
              {r.reason && <span class="related-reason">{r.reason}</span>}
              <span class="related-themes">
                {r.themes.map((t) => (
                  <span class="theme-tag">{t}</span>
                ))}
              </span>
              <span class="related-strength" data-strength={r.strength}>
                {'●'.repeat(Math.min(r.strength, 5))}{'○'.repeat(Math.max(0, 5 - r.strength))}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="page-nav">
      <a href={`${base}writings/`}>← All Writings</a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* Journey callout */
  .journey-callout {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border, rgba(255,255,255,0.1));
  }
  .journey-callout-heading {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-secondary, #999);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .journey-callout-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .journey-callout-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(184, 156, 255, 0.04);
    border: 1px solid rgba(184, 156, 255, 0.12);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .journey-callout-card:hover {
    background: rgba(184, 156, 255, 0.08);
    border-color: rgba(184, 156, 255, 0.25);
    transform: translateX(4px);
  }
  .jcc-emoji { font-size: 1.4rem; }
  .jcc-info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .jcc-name {
    color: var(--text-primary, #e0e0e0);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .jcc-position {
    color: var(--text-dim, #666);
    font-size: 0.75rem;
  }
  .jcc-arrow {
    color: var(--text-dim, #666);
    font-size: 1rem;
    transition: transform 0.2s;
  }
  .journey-callout-card:hover .jcc-arrow { transform: translateX(4px); }

  /* Related pieces */
  .related-pieces {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border, rgba(255,255,255,0.1));
  }

  .related-heading {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary, #999);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border, rgba(255,255,255,0.08));
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
  }

  .related-card:hover {
    border-color: var(--accent-aqua, #4ecdc4);
    background: rgba(78, 205, 196, 0.04);
    transform: translateY(-2px);
  }

  .related-title {
    color: var(--text-primary, #e0e0e0);
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .related-reason {
    font-family: var(--font-serif, Georgia, serif);
    font-style: italic;
    font-size: 0.78rem;
    color: var(--text-dim, #777);
    line-height: 1.4;
  }

  .related-themes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 2px;
  }

  .theme-tag {
    font-size: 0.68rem;
    color: var(--text-secondary, #888);
    background: rgba(255,255,255,0.04);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }

  .related-strength {
    font-size: 0.6rem;
    color: var(--accent-aqua, #4ecdc4);
    letter-spacing: 2px;
    opacity: 0.6;
    margin-top: 2px;
  }

  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
