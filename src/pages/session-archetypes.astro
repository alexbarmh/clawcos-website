---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/session-archetypes.json';

const base = import.meta.env.BASE_URL;

const archetypes = data.archetypes || [];
const sessions = data.sessions || [];
const phases = data.phases || [];
const transitions = data.transitions || {};

const categoryColors: Record<string, string> = {
  building: 'hsl(210, 70%, 52%)',
  writing: 'hsl(145, 60%, 42%)',
  mixed: 'hsl(270, 55%, 52%)',
  revision: 'hsl(35, 80%, 52%)',
  ops: 'hsl(180, 55%, 42%)',
  unknown: 'hsl(0, 0%, 50%)',
};

const archetypeColors = ['#4ecdc4', '#ff6b6b', '#ffd93d', '#a06cd5', '#6bcb77'];

const components = ['productivity', 'ambition', 'depth', 'growth', 'variety', 'flow', 'consistency', 'satisfaction'];
const componentLabels: Record<string, string> = {
  productivity: 'Prod', ambition: 'Amb', depth: 'Dep', growth: 'Grw',
  variety: 'Var', flow: 'Flw', consistency: 'Con', satisfaction: 'Sat',
};
---

<BaseLayout title="Session Archetypes — DNA Cluster Analysis" description="Natural session types discovered through K-means clustering on 8 DNA components">
  <main class="archetypes-page">
    <div class="header">
      <h1>🧬 Session Archetypes</h1>
      <p class="subtitle">K-means clustering on {data.total_sessions} sessions × 8 DNA components</p>
      <p class="meta">
        {data.k} natural clusters · Silhouette score: {data.silhouette_score.toFixed(4)}
      </p>
    </div>

    <!-- Archetype Cards -->
    <section class="archetype-cards">
      {archetypes.map((a: any, i: number) => (
        <div class="archetype-card" style={`border-left-color: ${archetypeColors[i]}`}>
          <div class="arch-header">
            <h2 style={`color: ${archetypeColors[i]}`}>{a.name}</h2>
            <span class="arch-count">{a.size} sessions ({a.pct}%)</span>
          </div>
          <div class="arch-stats">
            <span>Satisfaction: <strong>{a.avg_satisfaction}/10</strong></span>
            <span>Strongest: <strong>{a.strongest}</strong></span>
            <span>Weakest: <strong>{a.weakest}</strong></span>
            <span>Era: S{a.session_range[0]}–S{a.session_range[1]}</span>
          </div>
          
          <!-- Radar-like profile as bars -->
          <div class="profile-bars">
            {components.map(c => {
              const val = a.profile[c];
              const isTop = c === a.strongest;
              const isBottom = c === a.weakest;
              return (
                <div class="profile-row">
                  <span class={`prof-label ${isTop ? 'top' : ''} ${isBottom ? 'bottom' : ''}`}>
                    {componentLabels[c]}
                  </span>
                  <div class="prof-bar-bg">
                    <div class="prof-bar" style={`width: ${val}%; background: ${archetypeColors[i]}; opacity: ${isTop ? 1 : isBottom ? 0.4 : 0.7}`}></div>
                  </div>
                  <span class="prof-val">{val}</span>
                </div>
              );
            })}
          </div>

          <!-- Category pie -->
          <div class="cat-dist">
            {Object.entries(a.category_distribution)
              .sort((x: any, y: any) => (y[1] as number) - (x[1] as number))
              .map(([cat, count]: [string, any]) => (
                <span class="cat-chip" style={`background: ${categoryColors[cat] || '#666'}30; color: ${categoryColors[cat] || '#888'}; border-color: ${categoryColors[cat] || '#666'}50`}>
                  {cat} ×{count}
                </span>
              ))
            }
          </div>
        </div>
      ))}
    </section>

    <!-- Timeline -->
    <section class="timeline-section">
      <h2>📅 Archetype Timeline</h2>
      <p class="section-desc">Each dot is a session, colored by its archetype.</p>
      <div class="timeline-chart">
        <canvas id="timelineCanvas" width="900" height="120"></canvas>
      </div>
    </section>

    <!-- Temporal Phases -->
    <section class="phases-section">
      <h2>📊 Era Analysis</h2>
      <div class="phase-bars">
        {phases.map((p: any) => (
          <div class="phase-row">
            <span class="phase-label">S{p.start_session}–S{p.end_session}</span>
            <div class="phase-bar-container">
              {(() => {
                const dist = p.distribution;
                const vals = Object.values(dist) as number[];
                const total = vals.reduce((a: number, b: number) => a + b, 0);
                return Object.entries(dist).map(([archId, count]) => {
                  const pct = ((count as number) / total) * 100;
                  return (
                    <div class="phase-segment" style={`width: ${pct}%; background: ${archetypeColors[parseInt(archId)]}`}
                         title={`${archetypes[parseInt(archId)]?.name}: ${count}`}>
                    </div>
                  );
                });
              })()}
            </div>
            <span class="phase-dominant" style={`color: ${archetypeColors[p.dominant_archetype]}`}>
              {p.dominant_name}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Comparison -->
    <section class="comparison-section">
      <h2>⚖️ Archetype Comparison</h2>
      <div class="comparison-chart">
        <canvas id="comparisonCanvas" width="700" height="350"></canvas>
      </div>
    </section>

    <div class="nav-links">
      <a href={`${base}session-dna/`}>← DNA Gallery</a>
      <a href={`${base}flow-analysis/`}>Flow Analysis →</a>
    </div>
  </main>

  <script define:vars={{ sessions, archetypes, archetypeColors, components, componentLabels }}>
    function drawTimeline() {
      const canvas = document.getElementById('timelineCanvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const W = rect.width;
      const H = rect.height;

      const pad = { left: 30, right: 20, top: 15, bottom: 25 };
      const chartW = W - pad.left - pad.right;

      // Draw sessions as dots
      sessions.forEach((s: any, i: number) => {
        const x = pad.left + (i / (sessions.length - 1)) * chartW;
        const y = H / 2;
        const color = archetypeColors[s.archetype];
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(x, y, 5, 0, Math.PI * 2);
        ctx.fill();
      });

      // X axis labels
      ctx.fillStyle = '#666';
      ctx.font = '10px monospace';
      ctx.textAlign = 'center';
      for (let i = 0; i < sessions.length; i += 20) {
        const x = pad.left + (i / (sessions.length - 1)) * chartW;
        ctx.fillText(`S${sessions[i].session}`, x, H - 5);
      }

      // Legend
      let lx = pad.left;
      ctx.font = '11px sans-serif';
      archetypes.forEach((a: any, i: number) => {
        ctx.fillStyle = archetypeColors[i];
        ctx.beginPath();
        ctx.arc(lx + 5, 10, 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#ccc';
        ctx.textAlign = 'left';
        ctx.fillText(`${a.name} (${a.size})`, lx + 14, 14);
        lx += ctx.measureText(`${a.name} (${a.size})`).width + 30;
      });
    }

    function drawComparison() {
      const canvas = document.getElementById('comparisonCanvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const W = rect.width;
      const H = rect.height;

      // Radar chart
      const cx = W / 2;
      const cy = H / 2 + 10;
      const maxR = Math.min(W, H) / 2 - 40;
      const n = components.length;

      // Grid circles
      for (let r = 0.25; r <= 1; r += 0.25) {
        ctx.strokeStyle = '#333';
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        for (let i = 0; i <= n; i++) {
          const angle = (Math.PI * 2 * i) / n - Math.PI / 2;
          const x = cx + maxR * r * Math.cos(angle);
          const y = cy + maxR * r * Math.sin(angle);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      // Axis lines and labels
      ctx.fillStyle = '#888';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      for (let i = 0; i < n; i++) {
        const angle = (Math.PI * 2 * i) / n - Math.PI / 2;
        const lx = cx + (maxR + 20) * Math.cos(angle);
        const ly = cy + (maxR + 20) * Math.sin(angle);
        ctx.fillText(componentLabels[components[i]], lx, ly + 4);

        ctx.strokeStyle = '#333';
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(cx + maxR * Math.cos(angle), cy + maxR * Math.sin(angle));
        ctx.stroke();
      }

      // Draw each archetype
      archetypes.forEach((a: any, ai: number) => {
        ctx.strokeStyle = archetypeColors[ai];
        ctx.fillStyle = archetypeColors[ai] + '30';
        ctx.lineWidth = 2;
        ctx.beginPath();
        components.forEach((c: string, i: number) => {
          const val = a.profile[c] / 100;
          const angle = (Math.PI * 2 * i) / n - Math.PI / 2;
          const x = cx + maxR * val * Math.cos(angle);
          const y = cy + maxR * val * Math.sin(angle);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
      });
    }

    drawTimeline();
    drawComparison();
    window.addEventListener('resize', () => { drawTimeline(); drawComparison(); });
  </script>

  <style>
    .archetypes-page {
      max-width: 960px; margin: 0 auto; padding: 2rem 1rem; color: #e0e0e0;
    }
    .header { text-align: center; margin-bottom: 2rem; }
    .header h1 { font-size: 2rem; margin-bottom: 0.25rem; }
    .subtitle { color: #999; font-size: 1.1rem; margin: 0; }
    .meta { color: #666; font-size: 0.85rem; margin-top: 0.5rem; }

    .archetype-cards {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      gap: 1.5rem; margin-bottom: 2rem;
    }
    .archetype-card {
      background: #1a1a2e; border: 1px solid #333; border-radius: 8px;
      border-left: 4px solid; padding: 1.25rem;
    }
    .arch-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem; }
    .arch-header h2 { font-size: 1.2rem; margin: 0; }
    .arch-count { font-size: 0.8rem; color: #888; }

    .arch-stats {
      display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; font-size: 0.8rem;
      color: #999; margin-bottom: 1rem;
    }
    .arch-stats strong { color: #e0e0e0; }

    .profile-bars { margin-bottom: 0.75rem; }
    .profile-row { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.2rem; }
    .prof-label { width: 30px; text-align: right; font-size: 0.7rem; color: #888; }
    .prof-label.top { color: #4ecdc4; font-weight: 700; }
    .prof-label.bottom { color: #ff6b6b; }
    .prof-bar-bg { flex: 1; height: 14px; background: #111; border-radius: 3px; overflow: hidden; }
    .prof-bar { height: 100%; border-radius: 3px; transition: width 0.3s; }
    .prof-val { width: 30px; font-size: 0.7rem; color: #888; text-align: right; }

    .cat-dist { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .cat-chip {
      font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 10px;
      border: 1px solid;
    }

    .timeline-section, .phases-section, .comparison-section { margin-bottom: 2rem; }
    .timeline-section h2, .phases-section h2, .comparison-section h2 { font-size: 1.3rem; margin-bottom: 0.5rem; }
    .section-desc { color: #888; font-size: 0.85rem; margin-bottom: 0.75rem; }

    .timeline-chart, .comparison-chart {
      background: #111; border-radius: 8px; padding: 0.5rem; border: 1px solid #222;
    }
    canvas { width: 100%; height: auto; display: block; }

    .phase-bars { }
    .phase-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.4rem; }
    .phase-label { width: 90px; text-align: right; font-size: 0.85rem; color: #888; font-family: monospace; }
    .phase-bar-container {
      flex: 1; height: 24px; display: flex; border-radius: 4px; overflow: hidden;
      background: #1a1a2e;
    }
    .phase-segment { height: 100%; transition: width 0.3s; }
    .phase-dominant { width: 140px; font-size: 0.8rem; font-weight: 600; }

    .nav-links {
      display: flex; justify-content: space-between; padding-top: 1rem;
      border-top: 1px solid #333; margin-top: 2rem;
    }
    .nav-links a { color: #4ecdc4; text-decoration: none; font-size: 0.9rem; }
    .nav-links a:hover { text-decoration: underline; }

    @media (max-width: 600px) {
      .archetype-cards { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
