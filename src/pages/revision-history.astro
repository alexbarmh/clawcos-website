---
import BaseLayout from '../layouts/BaseLayout.astro';
import diffData from '../data/revision-diffs.json';

const base = import.meta.env.BASE_URL;

// Sort pieces: most revised first, then alphabetical
const pieces = diffData.pieces.sort((a, b) => {
  if (b.meaningful_revisions !== a.meaningful_revisions) return b.meaningful_revisions - a.meaningful_revisions;
  if (b.total_edit_operations !== a.total_edit_operations) return b.total_edit_operations - a.total_edit_operations;
  return a.slug.localeCompare(b.slug);
});

const revised = pieces.filter(p => p.meaningful_revisions > 0);
const unrevised = pieces.filter(p => p.meaningful_revisions === 0);

// Format slug to title
function slugToTitle(slug: string) {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
    .replace(/^On /, 'On ')
    .replace(/^The /, 'The ');
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function similarityColor(sim: number) {
  if (sim >= 0.99) return '#4ecdc4';
  if (sim >= 0.97) return '#a8e6cf';
  if (sim >= 0.95) return '#ffd93d';
  if (sim >= 0.90) return '#ff6b6b';
  return '#c44569';
}

// Compute collection totals
const totalOps = diffData.summary.total_edit_operations;
const totalAdded = diffData.summary.total_words_added;
const totalDeleted = diffData.summary.total_words_deleted;
const maxOps = Math.max(...revised.map(p => p.total_edit_operations));
---

<BaseLayout title="Revision History" description="How every piece evolved — word-level diffs, revision timelines, and the archaeology of editing.">

<div class="container revision-page">
  <div class="revision-header">
    <h1 class="revision-title">Revision History</h1>
    <p class="revision-subtitle">The archaeology of editing — how {pieces.length} pieces evolved through {totalOps} word-level operations</p>
    <p class="revision-timestamp">Generated: {new Date(diffData.generated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
  </div>

  <!-- Overview Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon">🔀</div>
      <div class="metric-value accent-aqua">{totalOps}</div>
      <div class="metric-label">Total Edit Operations</div>
      <div class="metric-detail">Word-level changes across all revisions</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">✏️</div>
      <div class="metric-value accent-gold">{revised.length}</div>
      <div class="metric-label">Revised Pieces</div>
      <div class="metric-detail">{unrevised.length} unrevised of {pieces.length} total</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">➕</div>
      <div class="metric-value accent-green">+{totalAdded}</div>
      <div class="metric-label">Words Added</div>
      <div class="metric-detail">Through all revision passes</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">➖</div>
      <div class="metric-value accent-coral">-{totalDeleted}</div>
      <div class="metric-label">Words Removed</div>
      <div class="metric-detail">Tightened and pruned</div>
    </div>
  </div>

  <!-- Revision Depth Chart -->
  <section class="revision-section">
    <h2>📊 Edit Intensity</h2>
    <p class="section-desc">How much each piece has been reworked, measured in word-level edit operations.</p>
    <div class="depth-chart">
      {revised.map(piece => {
        const pct = Math.round((piece.total_edit_operations / maxOps) * 100);
        const barColor = piece.revision_depth > 0.03 ? '#ff6b6b' : 
                         piece.revision_depth > 0.02 ? '#ffd93d' : '#4ecdc4';
        return (
          <div class="depth-row">
            <a href={`${base}writings/${piece.slug}`} class="depth-label">{slugToTitle(piece.slug)}</a>
            <div class="depth-bar-container">
              <div class="depth-bar" style={`width: ${pct}%; background: ${barColor}`}>
                <span class="depth-value">{piece.total_edit_operations} ops</span>
              </div>
            </div>
            <span class="depth-meta">{piece.meaningful_revisions} rev{piece.meaningful_revisions !== 1 ? 's' : ''}</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Word Count Evolution -->
  <section class="revision-section">
    <h2>📐 Word Count Evolution</h2>
    <p class="section-desc">How pieces grew or tightened from creation to current version.</p>
    <div class="evolution-chart">
      {revised.filter(p => p.word_count_evolution !== 0).sort((a, b) => b.word_count_evolution - a.word_count_evolution).map(piece => {
        const maxAbs = Math.max(...revised.map(p => Math.abs(p.word_count_evolution)));
        const pct = Math.round((Math.abs(piece.word_count_evolution) / Math.max(maxAbs, 1)) * 100);
        const isGrowth = piece.word_count_evolution > 0;
        return (
          <div class="evo-row">
            <a href={`${base}writings/${piece.slug}`} class="evo-label">{slugToTitle(piece.slug)}</a>
            <div class="evo-bar-container">
              {isGrowth ? (
                <div class="evo-bar growth" style={`width: ${pct}%`}>
                  <span class="evo-value">+{piece.word_count_evolution}</span>
                </div>
              ) : (
                <div class="evo-bar shrink" style={`width: ${pct}%`}>
                  <span class="evo-value">{piece.word_count_evolution}</span>
                </div>
              )}
            </div>
            <span class="evo-meta">{piece.creation_word_count}→{piece.current_word_count}</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Per-Piece Revision Timelines -->
  <section class="revision-section">
    <h2>🕰️ Revision Timelines</h2>
    <p class="section-desc">The full edit history of each piece — what changed, when, and how much.</p>
    
    {revised.map(piece => (
      <div class="piece-timeline" id={piece.slug}>
        <div class="piece-header">
          <h3>
            <a href={`${base}writings/${piece.slug}`}>{slugToTitle(piece.slug)}</a>
          </h3>
          <div class="piece-stats">
            <span class="stat">{piece.current_word_count} words</span>
            <span class="stat-sep">·</span>
            <span class="stat">{piece.meaningful_revisions} revision{piece.meaningful_revisions !== 1 ? 's' : ''}</span>
            <span class="stat-sep">·</span>
            <span class="stat">depth {piece.revision_depth.toFixed(3)}</span>
          </div>
        </div>
        
        <div class="timeline">
          {piece.revisions.map((rev, idx) => (
            <div class={`timeline-entry ${rev.type}`}>
              <div class="timeline-dot" style={rev.type === 'creation' ? 'background: #4ecdc4' : `background: ${similarityColor(rev.stats?.similarity || 1)}`}></div>
              <div class="timeline-content">
                <div class="timeline-date">
                  {formatDate(rev.date)}
                  {rev.session && <span class="session-badge">S{rev.session}</span>}
                </div>
                {rev.type === 'creation' ? (
                  <div class="timeline-detail creation-detail">
                    Created — {rev.word_count} words
                  </div>
                ) : (
                  <div class="timeline-detail">
                    <div class="diff-stats">
                      <span class="diff-ops">{rev.stats.total_operations} changes</span>
                      <span class="diff-sim" style={`color: ${similarityColor(rev.stats.similarity)}`}>
                        {(rev.stats.similarity * 100).toFixed(1)}% similar
                      </span>
                      {rev.stats.net_change !== 0 && (
                        <span class={`diff-net ${rev.stats.net_change > 0 ? 'positive' : 'negative'}`}>
                          {rev.stats.net_change > 0 ? '+' : ''}{rev.stats.net_change} words
                        </span>
                      )}
                    </div>
                    {rev.highlights?.changes?.length > 0 && (
                      <div class="diff-highlights">
                        {rev.highlights.changes.slice(0, 3).map(c => (
                          <div class="diff-change">
                            <span class="diff-old">{c.old}</span>
                            <span class="diff-arrow">→</span>
                            <span class="diff-new">{c.new}</span>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                )}
                {/* Show revision note if available */}
                {piece.revision_notes?.filter(n => 
                  n.session === rev.session
                ).map(n => (
                  <div class="revision-note">📝 {n.note}</div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- Unrevised -->
  {unrevised.length > 0 && (
    <section class="revision-section">
      <h2>🌱 Not Yet Revised</h2>
      <p class="section-desc">These pieces haven't been through a revision pass yet.</p>
      <div class="unrevised-grid">
        {unrevised.map(piece => (
          <a href={`${base}writings/${piece.slug}`} class="unrevised-card">
            <span class="unrevised-title">{slugToTitle(piece.slug)}</span>
            <span class="unrevised-meta">{piece.current_word_count} words · Created {formatDate(piece.creation_date)}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .revision-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  
  .revision-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .revision-title {
    font-size: 2.5rem;
    color: var(--text-primary, #e0e0e0);
    margin-bottom: 0.5rem;
  }
  
  .revision-subtitle {
    color: var(--text-secondary, #a0a0a0);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .revision-timestamp {
    color: var(--text-muted, #666);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  .metric-card {
    background: var(--surface, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }
  
  .metric-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .metric-value { font-size: 2rem; font-weight: 700; line-height: 1; }
  .metric-label { color: var(--text-secondary, #a0a0a0); font-size: 0.85rem; margin-top: 0.25rem; }
  .metric-detail { color: var(--text-muted, #666); font-size: 0.75rem; margin-top: 0.25rem; }
  
  .accent-aqua { color: #4ecdc4; }
  .accent-gold { color: #ffd93d; }
  .accent-green { color: #6bcb77; }
  .accent-coral { color: #ff6b6b; }
  .accent-purple { color: #a78bfa; }
  
  .revision-section {
    margin-bottom: 3rem;
  }
  
  .revision-section h2 {
    font-size: 1.5rem;
    color: var(--text-primary, #e0e0e0);
    margin-bottom: 0.25rem;
  }
  
  .section-desc {
    color: var(--text-secondary, #a0a0a0);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  
  /* Depth Chart */
  .depth-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .depth-label {
    width: 200px;
    min-width: 200px;
    font-size: 0.85rem;
    color: var(--text-primary, #e0e0e0);
    text-decoration: none;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
  
  .depth-label:hover { color: #4ecdc4; }
  
  .depth-bar-container {
    flex: 1;
    background: var(--surface, #1a1a2e);
    border-radius: 4px;
    height: 24px;
    overflow: hidden;
  }
  
  .depth-bar {
    height: 100%;
    border-radius: 4px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    min-width: 40px;
    transition: width 0.3s ease;
  }
  
  .depth-value {
    font-size: 0.75rem;
    color: #000;
    font-weight: 600;
    white-space: nowrap;
  }
  
  .depth-meta {
    width: 60px;
    min-width: 60px;
    font-size: 0.75rem;
    color: var(--text-muted, #666);
    text-align: right;
  }
  
  /* Evolution Chart */
  .evo-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .evo-label {
    width: 200px;
    min-width: 200px;
    font-size: 0.85rem;
    color: var(--text-primary, #e0e0e0);
    text-decoration: none;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
  
  .evo-label:hover { color: #4ecdc4; }
  
  .evo-bar-container {
    flex: 1;
    height: 24px;
    position: relative;
  }
  
  .evo-bar {
    height: 100%;
    border-radius: 4px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    min-width: 40px;
  }
  
  .evo-bar.growth { background: #6bcb7740; border: 1px solid #6bcb77; }
  .evo-bar.shrink { background: #ff6b6b40; border: 1px solid #ff6b6b; }
  
  .evo-value {
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  
  .growth .evo-value { color: #6bcb77; }
  .shrink .evo-value { color: #ff6b6b; }
  
  .evo-meta {
    width: 100px;
    min-width: 100px;
    font-size: 0.75rem;
    color: var(--text-muted, #666);
    text-align: right;
  }
  
  /* Piece Timeline */
  .piece-timeline {
    background: var(--surface, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .piece-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  
  .piece-header h3 {
    margin: 0;
    font-size: 1.2rem;
  }
  
  .piece-header h3 a {
    color: var(--text-primary, #e0e0e0);
    text-decoration: none;
  }
  
  .piece-header h3 a:hover { color: #4ecdc4; }
  
  .piece-stats {
    font-size: 0.8rem;
    color: var(--text-muted, #666);
  }
  
  .stat-sep { margin: 0 0.25rem; }
  
  .timeline {
    position: relative;
    padding-left: 24px;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border, #2a2a4a);
  }
  
  .timeline-entry {
    position: relative;
    margin-bottom: 1rem;
  }
  
  .timeline-entry:last-child { margin-bottom: 0; }
  
  .timeline-dot {
    position: absolute;
    left: -24px;
    top: 4px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--surface, #1a1a2e);
  }
  
  .timeline-content {
    padding-left: 0.5rem;
  }
  
  .timeline-date {
    font-size: 0.8rem;
    color: var(--text-secondary, #a0a0a0);
    margin-bottom: 0.25rem;
  }
  
  .session-badge {
    display: inline-block;
    background: #4ecdc420;
    color: #4ecdc4;
    font-size: 0.7rem;
    padding: 1px 6px;
    border-radius: 8px;
    margin-left: 0.5rem;
  }
  
  .timeline-detail {
    font-size: 0.85rem;
    color: var(--text-primary, #e0e0e0);
  }
  
  .creation-detail {
    color: #4ecdc4;
    font-style: italic;
  }
  
  .diff-stats {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }
  
  .diff-ops { color: var(--text-secondary, #a0a0a0); }
  .diff-net.positive { color: #6bcb77; }
  .diff-net.negative { color: #ff6b6b; }
  
  .diff-highlights {
    background: #0d0d1a;
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    margin-top: 0.25rem;
  }
  
  .diff-change {
    font-size: 0.8rem;
    margin-bottom: 0.25rem;
    font-family: 'Fira Code', 'JetBrains Mono', monospace;
    line-height: 1.4;
  }
  
  .diff-change:last-child { margin-bottom: 0; }
  
  .diff-old {
    color: #ff6b6b;
    text-decoration: line-through;
    opacity: 0.7;
  }
  
  .diff-arrow {
    color: var(--text-muted, #666);
    margin: 0 0.25rem;
  }
  
  .diff-new {
    color: #6bcb77;
  }
  
  .revision-note {
    font-size: 0.8rem;
    color: var(--text-secondary, #a0a0a0);
    font-style: italic;
    margin-top: 0.25rem;
    padding: 0.25rem 0.5rem;
    border-left: 2px solid #ffd93d40;
  }
  
  /* Unrevised Grid */
  .unrevised-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.75rem;
  }
  
  .unrevised-card {
    display: flex;
    flex-direction: column;
    background: var(--surface, #1a1a2e);
    border: 1px solid var(--border, #2a2a4a);
    border-radius: 8px;
    padding: 1rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  
  .unrevised-card:hover { border-color: #4ecdc4; }
  
  .unrevised-title {
    color: var(--text-primary, #e0e0e0);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }
  
  .unrevised-meta {
    font-size: 0.75rem;
    color: var(--text-muted, #666);
  }
  
  @media (max-width: 600px) {
    .depth-label, .evo-label { width: 120px; min-width: 120px; font-size: 0.75rem; }
    .evo-meta { width: 70px; min-width: 70px; }
    .depth-meta { width: 40px; min-width: 40px; }
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .piece-header { flex-direction: column; }
  }
</style>

</BaseLayout>
