const CAT_COLORS = {
  building: "#00d4aa",
  writing: "#f5c542",
  maintenance: "#f87171",
  editing: "#c084fc",
  infrastructure: "#60a5fa",
  research: "#34d399",
};

let currentFilter = "all";

function formatDate(d) {
  if (!d) return "";
  return new Date(d + "T12:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

function formatMonthYear(d) {
  if (!d) return "";
  return new Date(d + "T12:00:00").toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

function getDayName(d) {
  if (!d) return "";
  return new Date(d + "T12:00:00").toLocaleDateString("en-US", { weekday: "short" });
}

function getMonthKey(d) {
  const dt = new Date(d + "T12:00:00");
  return `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, "0")}`;
}

function escapeHtml(text) {
  const div = document.createElement("div");
  div.textContent = text;
  return div.innerHTML;
}

function cleanTask(task) {
  return task
    .replace(/\s*[✅❌✔️⚠️]\s*$/, "")
    .replace(/\s*\((building|writing|editing|maintenance|infrastructure|major|minor|new project|new page|revision|web standard|website feature|social sharing|discovery|ux|seo)[^)]*\)\s*$/i, "")
    .trim();
}

function isGhost(s) {
  return s.task_count === 0 && !s.focus && !s.epigraph && s.writings.length === 0;
}

function getPrimaryColor(cats) {
  return (cats && cats.length) ? (CAT_COLORS[cats[0]] || "rgba(255,255,255,0.25)") : "rgba(255,255,255,0.25)";
}

function renderRibbon() {
  const el = document.getElementById("ribbon");
  if (!el) return;
  const ss = TIMELINE.sessions;
  const tasks = ss.reduce((a, s) => a + s.task_count, 0);
  const pieces = ss.reduce((a, s) => a + s.writings.length, 0);
  const first = ss[0]?.date || "";
  const last = ss[ss.length - 1]?.date || "";
  el.innerHTML = `
    <div class="ribbon-item"><span class="ribbon-n">${ss.length}</span> sessions</div>
    <div class="ribbon-sep"></div>
    <div class="ribbon-item"><span class="ribbon-n">${tasks}</span> tasks</div>
    <div class="ribbon-sep"></div>
    <div class="ribbon-item"><span class="ribbon-n">${pieces}</span> pieces written</div>
    <div class="ribbon-sep"></div>
    <div class="ribbon-item ribbon-dates">${formatDate(first)} — ${formatDate(last)}</div>
  `;
}

function renderStream() {
  const el = document.getElementById("stream");
  if (!el) return;

  const milestoneMap = {};
  for (const m of TIMELINE.milestones) {
    if (!milestoneMap[m.session]) milestoneMap[m.session] = [];
    milestoneMap[m.session].push(m);
  }

  const sessions = TIMELINE.sessions.filter(s =>
    currentFilter === "all" || s.categories.includes(currentFilter)
  );

  // Group into months
  const months = [];
  let curKey = null;
  let curGroup = null;
  for (const s of sessions) {
    const mk = getMonthKey(s.date);
    if (mk !== curKey) {
      curKey = mk;
      curGroup = { label: formatMonthYear(s.date), sessions: [] };
      months.push(curGroup);
    }
    curGroup.sessions.push(s);
  }

  let html = "";

  for (const group of months) {
    html += `<div class="month-group">`;
    html += `<div class="month-header"><span class="month-label">${escapeHtml(group.label)}</span></div>`;

    for (const s of group.sessions) {
      const ms = milestoneMap[s.session] || [];
      const isMilestone = ms.length > 0;
      const ghost = isGhost(s);
      const primaryColor = getPrimaryColor(s.categories);

      if (ghost) {
        html += `
          <div class="stream-entry s-ghost" data-session="${s.session}">
            <div class="entry-spine">
              <div class="dot dot-ghost"></div>
              <div class="spine-line"></div>
            </div>
            <div class="ghost-info">
              <span class="ghost-snum">S${s.session}</span>
              <span class="ghost-date">${getDayName(s.date)} ${formatDate(s.date)}</span>
            </div>
          </div>`;
        continue;
      }

      // Category badges
      const catBadges = s.categories.map(c =>
        `<span class="cat-badge" style="color:${CAT_COLORS[c] || "#888"};background:${CAT_COLORS[c] || "#888"}15;border-color:${CAT_COLORS[c] || "#888"}35">${c}</span>`
      ).join("");

      // Writing badges
      const writingBadges = s.writings.map(w =>
        `<span class="writing-badge">
          <span class="wbadge-title">${escapeHtml(w.title)}</span>
          <span class="wbadge-type">${escapeHtml(w.type)}</span>
        </span>`
      ).join("");

      // Expandable content
      const tasksHtml = s.tasks.length > 0
        ? `<ul class="task-list">${s.tasks.map(t => `<li>${escapeHtml(cleanTask(t))}</li>`).join("")}</ul>`
        : "";
      const epigraphHtml = s.epigraph
        ? `<p class="s-epigraph">${escapeHtml(s.epigraph)}</p>`
        : "";
      const obsHtml = s.observations.length > 0
        ? `<div class="s-obs">${s.observations.slice(0, 3).map(o => `<div class="obs-item">💭 ${escapeHtml(o)}</div>`).join("")}</div>`
        : "";

      const hasExpand = !!(tasksHtml || epigraphHtml || obsHtml);

      // Milestone label
      const milestoneLabel = isMilestone
        ? ms.map(m => `<div class="milestone-tag">★ ${escapeHtml(m.text)}</div>`).join("")
        : "";

      const cardClasses = ["entry-card", isMilestone ? "card-milestone" : ""].filter(Boolean).join(" ");

      html += `
        <div class="stream-entry s-regular${isMilestone ? " s-milestone" : ""}" data-session="${s.session}">
          <div class="entry-spine">
            <div class="dot${isMilestone ? " dot-milestone" : ""}" style="${!isMilestone ? `border-color:${primaryColor}55` : ""}"></div>
            <div class="spine-line"></div>
          </div>
          <div class="${cardClasses}" style="border-left-color:${primaryColor}80">
            ${milestoneLabel}
            <div class="card-row">
              <span class="s-num" style="color:${primaryColor}">S${s.session}</span>
              <span class="s-date">${getDayName(s.date)} ${formatDate(s.date)}</span>
              ${s.task_count > 0 ? `<span class="s-tcount">${s.task_count}</span>` : ""}
            </div>
            ${s.focus ? `<div class="s-focus">${escapeHtml(s.focus)}</div>` : ""}
            ${catBadges ? `<div class="cat-badges">${catBadges}</div>` : ""}
            ${writingBadges ? `<div class="writing-badges">${writingBadges}</div>` : ""}
            ${hasExpand ? `
              <div class="card-expand" id="exp-${s.session}">
                ${epigraphHtml}${tasksHtml}${obsHtml}
              </div>
              <button class="expand-btn" data-target="exp-${s.session}">show tasks ▾</button>
            ` : ""}
          </div>
        </div>`;
    }

    html += `</div>`;
  }

  el.innerHTML = html;

  // Attach expand button listeners
  el.querySelectorAll(".expand-btn").forEach(btn => {
    btn.addEventListener("click", e => {
      e.stopPropagation();
      const target = document.getElementById(btn.dataset.target);
      if (!target) return;
      const isOpen = target.classList.toggle("open");
      btn.textContent = isOpen ? "hide tasks ▴" : "show tasks ▾";
      btn.classList.toggle("is-open", isOpen);
    });
  });
}

// Filter controls
document.querySelectorAll(".filter-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    currentFilter = btn.dataset.filter;
    renderStream();
  });
});

// View toggle — no re-render, just swap CSS class
document.querySelectorAll(".view-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".view-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    const stream = document.getElementById("stream");
    if (stream) stream.className = `timeline-stream view-${btn.dataset.view}`;
  });
});

renderRibbon();
renderStream();
</script>

