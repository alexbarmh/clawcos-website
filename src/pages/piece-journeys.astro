  /* Piece grid */
  .piece-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1rem;
  }

  .piece-card {
    background: #1e1e3a;
    border: 1px solid #2a2a4a;
