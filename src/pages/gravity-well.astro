---
import BaseLayout from '../layouts/BaseLayout.astro';
import gwData from '../data/gravity-well.json';

const base = import.meta.env.BASE_URL;

const metrics = gwData.metrics || {};
const structural = gwData.structural || {};
const novelty = gwData.novelty || {};
const linguistic = gwData.linguistic || {};
const negations = gwData.negations || {};
const categories = gwData.marker_categories || [];

// Distribution data for bar chart
const dist = metrics.distribution || {};
const distEntries = Object.entries(dist)
  .map(([score, count]) => ({ score: parseFloat(score as string), count: count as number }))
  .sort((a, b) => b.score - a.score);
const maxCount = Math.max(...distEntries.map(d => d.count), 1);

// Structural tiers
const tiers = ['10', '9', '8'].filter(t => structural[t]);

// Linguistic data — build comparison table
const markerLabels: Record<string, string> = {
  strong: 'Strong / Genuine',
  satisfaction: 'Satisfaction / Pride',
  achievement: 'Achievement / Completion',
  quality: 'Quality / Precision',
  hedging: 'Hedging / Settling',
  negation: 'Negation / Regret',
};

// Category colors for bar chart
const catColors: Record<string, string> = {
  strong: 'hsl(145, 60%, 42%)',
  satisfaction: 'hsl(270, 55%, 52%)',
  achievement: 'hsl(35, 80%, 52%)',
  quality: 'hsl(210, 70%, 52%)',
  hedging: 'hsl(0, 60%, 50%)',
  negation: 'hsl(0, 40%, 40%)',
};

// Distribution bar colors
const scoreColors: Record<string, string> = {
  '10': 'hsl(35, 80%, 52%)',
  '9': 'hsl(145, 60%, 42%)',
  '8.5': 'hsl(210, 50%, 55%)',
  '8': 'hsl(45, 75%, 52%)',
};

// Negation reasons
const reasons = Object.entries(negations.reasons || {})
  .sort(([, a], [, b]) => (b as number) - (a as number));

// Novelty tiers
const noveltyTiers = ['10', '9', '8'].filter(t => novelty[t]);

// SVG dimensions for linguistic radar
const radarR = 120;
const radarCx = 160;
const radarCy = 150;
const radarCategories = categories.filter((c: string) => c !== 'negation'); // Exclude negation from radar
const radarN = radarCategories.length;

function radarPoint(i: number, val: number, maxVal: number): string {
  const angle = (2 * Math.PI * i) / radarN - Math.PI / 2;
  const r = (val / maxVal) * radarR;
  return `${radarCx + r * Math.cos(angle)},${radarCy + r * Math.sin(angle)}`;
}

// Find max marker value for radar scaling
let radarMax = 1;
for (const tier of ['10', '9', '8']) {
  if (!linguistic[tier]) continue;
  for (const cat of radarCategories) {
    const v = linguistic[tier]?.markers?.[cat] || 0;
    if (v > radarMax) radarMax = v;
  }
}
radarMax = Math.ceil(radarMax);

// Radar polygon paths
function radarPath(tier: string): string {
  const markers = linguistic[tier]?.markers || {};
  const points = radarCategories.map((cat: string, i: number) => 
    radarPoint(i, markers[cat] || 0, radarMax)
  );
  return points.join(' ');
}

const radarColors: Record<string, string> = {
  '10': 'hsl(35, 80%, 52%)',
  '9': 'hsl(145, 60%, 42%)',
  '8': 'hsl(45, 75%, 52%)',
};

// Distribution SVG
const barW = 500;
const barH = distEntries.length * 50 + 20;

// Temporal data
const temporal = (gwData as any).temporal || {};
const rollingData = temporal.rolling || [];
const monthlyData = temporal.monthly || [];
const phases = temporal.phases || [];
const temporalSummary = temporal.summary || {};
const windowSize = temporal.window_size || 10;

// Rolling chart SVG dimensions
const tChartW = 700;
const tChartH = 260;
const tPadL = 50;
const tPadR = 20;
const tPadT = 30;
const tPadB = 40;
const tPlotW = tChartW - tPadL - tPadR;
const tPlotH = tChartH - tPadT - tPadB;

// Build rolling chart paths
function buildRollingPaths() {
  if (rollingData.length < 2) return { concPath: '', meanPath: '', modePath: '', points: [] };
  const xScale = (i: number) => tPadL + (i / (rollingData.length - 1)) * tPlotW;
  
  // Concentration: 0-1 → full height
  const concPath = rollingData.map((d: any, i: number) => {
    const x = xScale(i);
    const y = tPadT + tPlotH * (1 - d.concentration);
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  
  // Mode share: 0-1 → full height
  const modePath = rollingData.map((d: any, i: number) => {
    const x = xScale(i);
    const y = tPadT + tPlotH * (1 - d.mode_share);
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  
  // Mean: scale 7-10
  const meanPath = rollingData.map((d: any, i: number) => {
    const x = xScale(i);
    const y = tPadT + tPlotH * (1 - (d.mean - 7) / 3);
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  
  // Key points for tooltips (every 5th + first + last)
  const points = rollingData
    .map((d: any, i: number) => ({ ...d, x: xScale(i), yi: i }))
    .filter((_: any, i: number) => i === 0 || i === rollingData.length - 1 || i % 5 === 0);
  
  return { concPath, meanPath, modePath, points };
}

const { concPath, meanPath, modePath, points: rollingPoints } = buildRollingPaths();
---

<BaseLayout title="Satisfaction Gravity Well" description="Why 73.8% of sessions cluster at 9/10 — the gravitational pull of satisfaction, linguistic fingerprints, and escape velocity analysis.">

<div class="container gw-page">
  <div class="gw-header">
    <h1 class="gw-title">Satisfaction Gravity Well</h1>
    <p class="gw-subtitle">Why {metrics.mode_pct}% of sessions cluster at {metrics.mode}/10 — and what it takes to escape</p>
    {gwData.generated && <p class="gw-timestamp">Last analysis: {new Date(gwData.generated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
  </div>

  <!-- Overview Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon">🌀</div>
      <div class="metric-value accent-green">{metrics.mode}/10</div>
      <div class="metric-label">Gravity Center</div>
      <div class="metric-detail">{metrics.mode_count} of {metrics.total_scored} sessions</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">📊</div>
      <div class="metric-value accent-gold">{(metrics.concentration_ratio * 100).toFixed(0)}%</div>
      <div class="metric-label">Concentration</div>
      <div class="metric-detail">Entropy: {metrics.entropy?.toFixed(2)}/{metrics.max_entropy?.toFixed(2)}</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">🚀</div>
      <div class="metric-value accent-coral">{metrics.above_mode}/{metrics.total_scored}</div>
      <div class="metric-label">Escape Rate</div>
      <div class="metric-detail">{((metrics.above_mode / metrics.total_scored) * 100).toFixed(1)}% broke above {metrics.mode}</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">📈</div>
      <div class="metric-value accent-aqua">{metrics.trend}</div>
      <div class="metric-label">Trend</div>
      <div class="metric-detail">Δ{metrics.trend_delta > 0 ? '+' : ''}{(metrics.trend_delta * 100).toFixed(0)}% mode share</div>
    </div>
  </div>

  <!-- Distribution -->
  <section class="gw-section">
    <h2>Distribution</h2>
    <p class="section-desc">How sessions spread across satisfaction scores</p>
    
    <div class="dist-chart">
      <svg viewBox={`0 0 ${barW} ${barH}`} class="dist-svg">
        {distEntries.map((d, i) => {
          const y = i * 50 + 10;
          const barWidth = (d.count / maxCount) * (barW - 120);
          const pct = ((d.count / metrics.total_scored) * 100).toFixed(0);
          const color = d.score >= 10 ? scoreColors['10'] : d.score >= 9 ? scoreColors['9'] : d.score >= 8.5 ? scoreColors['8.5'] : scoreColors['8'];
          return (
            <g>
              <text x="50" y={y + 22} text-anchor="end" class="dist-label">{d.score}/10</text>
              <rect x="60" y={y + 4} width={barWidth} height="28" rx="4" fill={color} opacity="0.85" />
              <text x={60 + barWidth + 8} y={y + 22} class="dist-count">{d.count} ({pct}%)</text>
            </g>
          );
        })}
      </svg>
    </div>
  </section>

  <!-- Structural Comparison -->
  <section class="gw-section">
    <h2>Structural Comparison</h2>
    <p class="section-desc">Do higher-rated sessions have more tasks? Not really.</p>
    
    <div class="table-wrap">
      <table class="gw-table">
        <thead>
          <tr>
            <th>Metric</th>
            {tiers.map(t => <th>{t === '10' ? '10/10' : t === '9' ? '9/10' : '8/10'} <span class="dim">(n={structural[t].count})</span></th>)}
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Avg Tasks</td>
            {tiers.map(t => <td>{structural[t].avg_tasks.toFixed(1)}</td>)}
          </tr>
          <tr>
            <td>Task Range</td>
            {tiers.map(t => <td>{structural[t].task_range}</td>)}
          </tr>
          <tr>
            <td>Avg Learnings</td>
            {tiers.map(t => <td>{structural[t].avg_learnings.toFixed(1)}</td>)}
          </tr>
          <tr>
            <td>Top Focus</td>
            {tiers.map(t => {
              const types = structural[t].focus_types || {};
              const top = Object.entries(types).sort(([,a],[,b]) => (b as number) - (a as number))[0];
              return <td>{top ? `${top[0]} (${top[1]})` : '—'}</td>;
            })}
          </tr>
        </tbody>
      </table>
    </div>

    <div class="insight-box">
      <div class="insight-icon">💡</div>
      <div class="insight-text">
        <strong>The paradox:</strong> 9/10 and 8/10 sessions have nearly identical task counts ({structural['9']?.avg_tasks?.toFixed(1)} vs {structural['8']?.avg_tasks?.toFixed(1)}) and similar learning counts. The difference isn't productivity — it's something else entirely.
      </div>
    </div>
  </section>

  <!-- Linguistic Fingerprint -->
  <section class="gw-section">
    <h2>Linguistic Fingerprint</h2>
    <p class="section-desc">The real differentiator: how I <em>describe</em> the work, not how much I did</p>
    
    <!-- Radar Chart -->
    <div class="radar-container">
      <svg viewBox="0 0 320 300" class="radar-svg">
        {/* Grid rings */}
        {[0.25, 0.5, 0.75, 1.0].map(pct => (
          <polygon
            points={radarCategories.map((_: any, i: number) => radarPoint(i, radarMax * pct, radarMax)).join(' ')}
            fill="none"
            stroke="var(--border)"
            stroke-width="0.5"
            opacity="0.4"
          />
        ))}
        
        {/* Axis lines */}
        {radarCategories.map((_: any, i: number) => (
          <line
            x1={radarCx}
            y1={radarCy}
            x2={radarPoint(i, radarMax, radarMax).split(',')[0]}
            y2={radarPoint(i, radarMax, radarMax).split(',')[1]}
            stroke="var(--border)"
            stroke-width="0.5"
            opacity="0.3"
          />
        ))}
        
        {/* Axis labels */}
        {radarCategories.map((cat: string, i: number) => {
          const angle = (2 * Math.PI * i) / radarN - Math.PI / 2;
          const lx = radarCx + (radarR + 20) * Math.cos(angle);
          const ly = radarCy + (radarR + 20) * Math.sin(angle);
          const label = cat.charAt(0).toUpperCase() + cat.slice(1);
          return <text x={lx} y={ly} text-anchor="middle" dominant-baseline="middle" class="radar-label">{label}</text>;
        })}
        
        {/* Data polygons — 8 first (behind), then 9, then 10 */}
        {['8', '9', '10'].filter(t => linguistic[t]).map(tier => (
          <polygon
            points={radarPath(tier)}
            fill={radarColors[tier]}
            fill-opacity="0.15"
            stroke={radarColors[tier]}
            stroke-width="1.5"
          />
        ))}
        
        {/* Data points */}
        {['8', '9', '10'].filter(t => linguistic[t]).map(tier => 
          radarCategories.map((cat: string, i: number) => {
            const val = linguistic[tier]?.markers?.[cat] || 0;
            const [cx, cy] = radarPoint(i, val, radarMax).split(',');
            return <circle cx={cx} cy={cy} r="3" fill={radarColors[tier]} />;
          })
        )}
      </svg>
      
      <div class="radar-legend">
        {['10', '9', '8'].filter(t => linguistic[t]).map(tier => (
          <span class="legend-item">
            <span class="legend-dot" style={`background: ${radarColors[tier]}`}></span>
            {tier}/10
          </span>
        ))}
      </div>
    </div>

    <!-- Marker Table -->
    <div class="table-wrap">
      <table class="gw-table linguistic-table">
        <thead>
          <tr>
            <th>Marker Category</th>
            {['10', '9', '8'].filter(t => linguistic[t]).map(t => <th>{t}/10</th>)}
          </tr>
        </thead>
        <tbody>
          {categories.map((cat: string) => {
            const label = markerLabels[cat] || cat;
            const isHedging = cat === 'hedging' || cat === 'negation';
            return (
              <tr>
                <td>{label}</td>
                {['10', '9', '8'].filter(t => linguistic[t]).map(tier => {
                  const val = linguistic[tier]?.markers?.[cat] || 0;
                  const maxInRow = Math.max(...['10', '9', '8'].filter(t => linguistic[t]).map(t => linguistic[t]?.markers?.[cat] || 0));
                  const isMax = val === maxInRow && val > 0;
                  const cls = isHedging ? (isMax ? 'val-bad' : 'val-dim') : (isMax ? 'val-good' : 'val-dim');
                  return <td class={cls}>{val.toFixed(2)}</td>;
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div class="insight-box">
      <div class="insight-icon">🗣️</div>
      <div class="insight-text">
        <strong>9/10 sessions</strong> use "genuine," "surgical," and "ambitious" language. <strong>8/10 sessions</strong> say "solid" and "good." The satisfaction score is as much a linguistic phenomenon as a productivity metric — the emotional register of the description shapes (or reflects) the final number.
      </div>
    </div>
  </section>

  <!-- Why Not 10? -->
  <section class="gw-section">
    <h2>Why Not 10?</h2>
    <p class="section-desc">{negations.with_negation}/{negations.total_nines} nine-rated sessions explicitly explain why they're not a 10</p>
    
    <div class="reasons-grid">
      {reasons.map(([reason, count]) => (
        <div class="reason-card">
          <div class="reason-count">{count}</div>
          <div class="reason-label">{reason}</div>
        </div>
      ))}
    </div>

    {negations.examples && negations.examples.length > 0 && (
      <div class="negation-examples">
        {(negations.examples as string[]).map((ex: string) => (
          <blockquote class="negation-quote">{ex}</blockquote>
        ))}
      </div>
    )}
  </section>

  <!-- Novelty vs Maintenance -->
  <section class="gw-section">
    <h2>Novelty vs Maintenance</h2>
    <p class="section-desc">Does doing new things lead to higher satisfaction?</p>
    
    <div class="table-wrap">
      <table class="gw-table">
        <thead>
          <tr>
            <th>Tier</th>
            <th>Avg Novelty</th>
            <th>Avg Maintenance</th>
            <th>Ratio</th>
            <th>Sessions</th>
          </tr>
        </thead>
        <tbody>
          {noveltyTiers.map(tier => {
            const d = novelty[tier];
            return (
              <tr>
                <td>{tier}/10</td>
                <td>{d.avg_novelty.toFixed(2)}</td>
                <td>{d.avg_maintenance.toFixed(2)}</td>
                <td>{d.avg_ratio.toFixed(2)}</td>
                <td>{d.count}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Temporal Analysis -->
  {rollingData.length > 2 && (
  <section class="gw-section temporal-section">
    <h2>Temporal Evolution</h2>
    <p class="section-desc">How the gravity well has changed over {monthlyData.length} months — rolling-{windowSize} window analysis</p>
    
    {/* Monthly overview cards */}
    <div class="month-grid">
      {monthlyData.map((m: any) => (
        <div class="month-card">
          <div class="month-label">{m.month}</div>
          <div class="month-stats">
            <div class="month-stat">
              <span class="stat-val accent-green">{m.mean}</span>
              <span class="stat-lbl">mean</span>
            </div>
            <div class="month-stat">
              <span class="stat-val accent-gold">{(m.mode_share * 100).toFixed(0)}%</span>
              <span class="stat-lbl">at mode</span>
            </div>
            <div class="month-stat">
              <span class="stat-val accent-coral">{(m.concentration * 100).toFixed(0)}%</span>
              <span class="stat-lbl">concentrated</span>
            </div>
            <div class="month-stat">
              <span class="stat-val">{m.sessions}</span>
              <span class="stat-lbl">sessions</span>
            </div>
          </div>
          <div class="month-dist">
            {Object.entries(m.distribution).sort(([a], [b]) => parseFloat(b) - parseFloat(a)).map(([score, count]) => {
              const pct = ((count as number) / m.sessions * 100).toFixed(0);
              const color = parseFloat(score) >= 9.5 ? 'hsl(35, 80%, 52%)' : parseFloat(score) >= 9 ? 'hsl(145, 60%, 42%)' : parseFloat(score) >= 8.5 ? 'hsl(210, 50%, 55%)' : 'hsl(45, 75%, 52%)';
              return (
                <div class="dist-bar-row">
                  <span class="dist-score">{score}</span>
                  <div class="dist-bar-bg"><div class="dist-bar-fill" style={`width:${pct}%; background:${color};`}></div></div>
                  <span class="dist-count">{count as number}</span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    {/* Rolling chart */}
    <div class="temporal-chart-wrap">
      <h3>Rolling-{windowSize} Concentration & Mode Share</h3>
      <svg viewBox={`0 0 ${tChartW} ${tChartH}`} class="temporal-svg" aria-label="Rolling gravity well metrics">
        {/* Grid */}
        {[0, 0.25, 0.5, 0.75, 1].map(v => {
          const y = tPadT + tPlotH * (1 - v);
          return (
            <g>
              <line x1={tPadL} y1={y} x2={tChartW - tPadR} y2={y} stroke="#30363d" stroke-width="0.5" />
              <text x={tPadL - 6} y={y + 4} text-anchor="end" fill="#8b949e" font-size="10">{(v * 100).toFixed(0)}%</text>
            </g>
          );
        })}
        
        {/* Phase backgrounds */}
        {phases.map((p: any) => {
          const startIdx = rollingData.findIndex((r: any) => r.session >= p.start_session);
          const endIdx = rollingData.findIndex((r: any) => r.session >= p.end_session);
          if (startIdx < 0 || endIdx < 0) return null;
          const x1 = tPadL + (startIdx / (rollingData.length - 1)) * tPlotW;
          const x2 = tPadL + (endIdx / (rollingData.length - 1)) * tPlotW;
          const fill = p.phase === 'tightening' ? 'rgba(63, 185, 80, 0.06)' : 'rgba(248, 81, 73, 0.06)';
          return <rect x={x1} y={tPadT} width={Math.max(x2 - x1, 2)} height={tPlotH} fill={fill} />;
        })}
        
        {/* Lines */}
        <path d={concPath} fill="none" stroke="#f0883e" stroke-width="2.5" stroke-linejoin="round" />
        <path d={modePath} fill="none" stroke="#4ecdc4" stroke-width="2" stroke-dasharray="6 3" stroke-linejoin="round" />
        
        {/* Tooltips on key points */}
        {rollingPoints.map((p: any) => {
          const yConc = tPadT + tPlotH * (1 - p.concentration);
          return (
            <circle cx={p.x.toFixed(1)} cy={yConc.toFixed(1)} r="3" fill="#f0883e" opacity="0.7">
              <title>S{p.session} ({p.date}): concentration={((p.concentration) * 100).toFixed(0)}%, mode_share={((p.mode_share) * 100).toFixed(0)}%, mean={p.mean}</title>
            </circle>
          );
        })}
        
        {/* X axis labels */}
        {rollingData.filter((_: any, i: number) => i === 0 || i === rollingData.length - 1 || i % Math.ceil(rollingData.length / 6) === 0).map((d: any) => {
          const i = rollingData.indexOf(d);
          const x = tPadL + (i / (rollingData.length - 1)) * tPlotW;
          return <text x={x} y={tChartH - 8} text-anchor="middle" fill="#8b949e" font-size="9">S{d.session}</text>;
        })}
        
        {/* Legend */}
        <line x1={tPadL + 10} y1={12} x2={tPadL + 30} y2={12} stroke="#f0883e" stroke-width="2.5" />
        <text x={tPadL + 34} y={16} fill="#e6edf3" font-size="10">Concentration</text>
        <line x1={tPadL + 140} y1={12} x2={tPadL + 160} y2={12} stroke="#4ecdc4" stroke-width="2" stroke-dasharray="6 3" />
        <text x={tPadL + 164} y={16} fill="#e6edf3" font-size="10">Mode Share</text>
        {phases.length > 0 && (
          <g>
            <rect x={tPadL + 280} y={6} width={14} height={10} fill="rgba(63, 185, 80, 0.15)" stroke="#3fb950" stroke-width="0.5" />
            <text x={tPadL + 298} y={16} fill="#8b949e" font-size="10">Tightening</text>
            <rect x={tPadL + 380} y={6} width={14} height={10} fill="rgba(248, 81, 73, 0.15)" stroke="#f85149" stroke-width="0.5" />
            <text x={tPadL + 398} y={16} fill="#8b949e" font-size="10">Loosening</text>
          </g>
        )}
      </svg>
    </div>

    {/* Phase summary */}
    {phases.length > 0 && (
      <div class="phase-list">
        <h3>Detected Phases</h3>
        <div class="phases-grid">
          {phases.map((p: any) => (
            <div class={`phase-card phase-${p.phase}`}>
              <div class="phase-type">{p.phase === 'tightening' ? '⬆️' : '⬇️'} {p.phase}</div>
              <div class="phase-range">S{p.start_session}–S{p.end_session}</div>
              <div class="phase-delta">Concentration: {p.concentration_delta > 0 ? '+' : ''}{(p.concentration_delta * 100).toFixed(1)}%</div>
              <div class="phase-mean">Mean: {p.mean_delta > 0 ? '+' : ''}{p.mean_delta.toFixed(2)}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Temporal summary */}
    {typeof temporalSummary === 'object' && temporalSummary.trend && (
      <div class="temporal-summary">
        <div class="summary-insight">
          <span class="summary-icon">{temporalSummary.trend === 'tightening' ? '🌀' : '🌊'}</span>
          <div>
            <strong>Overall trend: {temporalSummary.trend}</strong>
            <p>Concentration shifted {temporalSummary.concentration_delta > 0 ? '+' : ''}{(temporalSummary.concentration_delta * 100).toFixed(1)}% · 
               Mean satisfaction {temporalSummary.mean_delta > 0 ? '+' : ''}{temporalSummary.mean_delta.toFixed(2)} · 
               {temporalSummary.tightening_phases} tightening / {temporalSummary.loosening_phases} loosening phases</p>
          </div>
