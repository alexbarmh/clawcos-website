---
import BaseLayout from '../layouts/BaseLayout.astro';
import healthData from '../data/collection-health.json';
import historyRaw from '../data/health-history.json';
const base = import.meta.env.BASE_URL;
const timeline = historyRaw?.timeline || [];
---

<BaseLayout title="Collection Health" description="Workshop diagnostics for every piece in the collection — suggestions, health scores, and the ongoing work of revision.">

<div class="container health-page">
  <div class="health-header">
    <h1 class="health-title">Collection Health</h1>
    <p class="health-subtitle">Workshop diagnostics across {healthData.collection.total_pieces} pieces — what needs attention, what's clean, and where the patterns are</p>
    <p class="health-timestamp">Last analyzed: {new Date(healthData.generated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
  </div>

  <!-- Overview Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon">🔧</div>
      <div class="metric-value accent-aqua">{healthData.collection.total_suggestions}</div>
      <div class="metric-label">Total Suggestions</div>
      <div class="metric-detail">{healthData.collection.by_priority.high} high · {healthData.collection.by_priority.medium} medium · {healthData.collection.by_priority.low} low</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">📊</div>
      <div class="metric-value accent-gold">{healthData.collection.avg_health_score}</div>
      <div class="metric-label">Avg Health Score</div>
      <div class="metric-detail">0 = needs work · 100 = clean</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">📝</div>
      <div class="metric-value accent-purple">{healthData.collection.total_pieces}</div>
      <div class="metric-label">Pieces Analyzed</div>
      <div class="metric-detail">{healthData.collection.by_type.essay?.count || 0} essays · {healthData.collection.by_type.fiction?.count || 0} fiction · {healthData.collection.by_type.poetry?.count || 0} poetry</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">🔁</div>
      <div class="metric-value accent-coral">{Object.keys(healthData.collection.by_category).length}</div>
      <div class="metric-label">Issue Categories</div>
      <div class="metric-detail">Most common: {Object.entries(healthData.collection.by_category)[0]?.[0] || 'none'}</div>
    </div>
  </div>

  <!-- Health Over Time -->
  {timeline.length >= 2 && (
    <section class="health-section">
      <h2>📈 Health Over Time</h2>
      <p class="section-desc">How the collection's average health score evolves across revision sessions. Each point is a deploy snapshot.</p>
      <div class="history-chart" id="history-chart"></div>
      <div class="history-legend">
        <span class="legend-item"><span class="legend-line" style="background: #4ecdc4;"></span> Avg Health</span>
        <span class="legend-item"><span class="legend-line legend-dashed" style="background: #ff6b6b;"></span> Total Suggestions</span>
      </div>
      <div class="history-stats">
        <span class="history-trend">{timeline[0].avgHealth} → {timeline[timeline.length - 1].avgHealth} over {timeline.length} snapshots</span>
      </div>
    </section>
  )}

  {timeline.length === 1 && (
    <section class="health-section">
      <h2>📈 Health Over Time</h2>
      <p class="section-desc">Tracking begins today. The trend chart will appear after the next revision session deploy.</p>
      <div class="history-single">
        <span class="history-single-value">{timeline[0].avgHealth}</span>
        <span class="history-single-label">First snapshot — {timeline[0].date}</span>
      </div>
    </section>
  )}

  <!-- Health Ranking -->
  <section class="health-section">
    <h2>🩺 Health Ranking</h2>
    <p class="section-desc">Every piece ranked by health score. Lower scores mean more workshop suggestions — more room to grow.</p>
    <div class="ranking-chart" id="ranking-chart">
      {healthData.pieces.map((piece) => {
        const barColor = piece.health_score >= 70 ? '#4ecdc4' :
                         piece.health_score >= 40 ? '#f4d35e' :
                         piece.health_score >= 20 ? '#ff8c42' : '#ff6b6b';
        const typeEmoji = piece.type === 'essay' ? '📝' : piece.type === 'fiction' ? '📖' : '🎵';
        return (
          <div class="ranking-row">
            <div class="ranking-label">
              <span class="type-emoji">{typeEmoji}</span>
              <a href={`${base}writings/${piece.slug}/`} class="piece-link">{piece.title}</a>
            </div>
            <div class="ranking-bar-wrap">
              <div class="ranking-bar" style={`width: ${Math.max(piece.health_score, 2)}%; background: ${barColor};`}>
                <span class="bar-score">{piece.health_score}</span>
              </div>
            </div>
            <div class="ranking-suggestions">
              {piece.suggestions_high > 0 && <span class="pill pill-high">{piece.suggestions_high}</span>}
              {piece.suggestions_medium > 0 && <span class="pill pill-medium">{piece.suggestions_medium}</span>}
              {piece.suggestions_low > 0 && <span class="pill pill-low">{piece.suggestions_low}</span>}
            </div>
          </div>
        );
      })}
    </div>
    <div class="chart-legend-inline">
      <span><span class="pill pill-high">N</span> high priority</span>
      <span><span class="pill pill-medium">N</span> medium</span>
      <span><span class="pill pill-low">N</span> low</span>
    </div>
  </section>

  <!-- Category Breakdown -->
  <section class="health-section">
    <h2>📋 Suggestion Categories</h2>
    <p class="section-desc">What kinds of issues appear most across the collection.</p>
    <div class="category-grid">
      {Object.entries(healthData.collection.by_category).map(([cat, count]) => {
        const total = healthData.collection.total_suggestions;
        const pct = Math.round((count / total) * 100);
        const icons = {
          repetition: '🔁', rhythm: '🥁', groundedness: '🌱',
          structure: '🏗️', diction: '✏️', confidence: '💪'
        } as any;
        const catColors = {
          repetition: '#ff6b6b', rhythm: '#f4d35e', groundedness: '#4ecdc4',
          structure: '#b388ff', diction: '#ff8c42', confidence: '#64b5f6'
        } as any;
        return (
          <div class="category-card">
            <div class="category-icon">{icons[cat] || '📌'}</div>
            <div class="category-name">{cat}</div>
            <div class="category-bar-wrap">
              <div class="category-bar" style={`width: ${pct}%; background: ${catColors[cat] || '#888'};`}></div>
            </div>
            <div class="category-count">{count} <span class="category-pct">({pct}%)</span></div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Type Comparison -->
  <section class="health-section">
    <h2>📖 By Type</h2>
    <p class="section-desc">How different genres compare in health and complexity.</p>
    <div class="type-grid">
      {Object.entries(healthData.collection.by_type).map(([type, stats]) => {
        const emojis = { essay: '📝', fiction: '📖', poetry: '🎵' } as any;
        const pieces = healthData.pieces.filter((p: any) => p.type === type);
        const avgHealth = pieces.length > 0
          ? Math.round(pieces.reduce((s: number, p: any) => s + p.health_score, 0) / pieces.length)
          : 0;
        return (
          <div class="type-card">
            <div class="type-emoji-big">{emojis[type] || '📄'}</div>
            <div class="type-name">{type}</div>
            <div class="type-stats">
              <div class="type-stat"><span class="stat-val">{(stats as any).count}</span> pieces</div>
              <div class="type-stat"><span class="stat-val">{(stats as any).avg_words}</span> avg words</div>
              <div class="type-stat"><span class="stat-val">{(stats as any).avg_suggestions}</span> avg suggestions</div>
              <div class="type-stat"><span class="stat-val">{avgHealth}</span> avg health</div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Cross-Cutting Patterns (from Revision Pipeline) -->
  {healthData.patterns && healthData.patterns.length > 0 && (
    <section class="health-section">
      <h2>🔍 Cross-Cutting Patterns</h2>
      <p class="section-desc">Habits and weaknesses that appear across multiple pieces — the revision pipeline detects these by combining workshop, style, and automated analysis signals.</p>
      {healthData.collection.revision_grade && (
        <div class="revision-grade-banner">
          <span class="revision-grade-label">Collection Revision Grade:</span>
          <span class={`revision-grade grade-${healthData.collection.revision_grade}`}>{healthData.collection.revision_grade}</span>
          <span class="revision-grade-detail">Avg revision score: {healthData.collection.avg_revision_score} (lower is cleaner)</span>
        </div>
      )}
      <div class="patterns-list">
        {healthData.patterns.map((p: any) => {
          const severityColor = p.severity === 'high' ? '#ff6b6b' : p.severity === 'medium' ? '#f4d35e' : '#64b5f6';
          const severityIcon = p.severity === 'high' ? '🔴' : p.severity === 'medium' ? '🟡' : '🔵';
          return (
            <div class="pattern-card" style={`border-left-color: ${severityColor};`}>
              <div class="pattern-header">
                <span class="pattern-severity">{severityIcon}</span>
                <span class="pattern-desc">{p.description}</span>
              </div>
              <div class="pattern-suggestion">{p.suggestion}</div>
              {p.detail && p.detail.length > 0 && (
                <div class="pattern-detail">
                  {p.detail.slice(0, 3).map((d: string) => (
                    <div class="pattern-detail-item">• {d}</div>
                  ))}
                </div>
              )}
              <div class="pattern-pieces">
                Affects: {p.pieces.slice(0, 5).map((slug: string) => slug.replace(/-/g, ' ')).join(', ')}
                {p.pieces.length > 5 ? ` +${p.pieces.length - 5} more` : ''}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Individual Piece Details (expandable) -->
  <section class="health-section">
    <h2>🔍 Piece Details</h2>
    <p class="section-desc">Click a piece to see its workshop diagnostics.</p>
    <div class="piece-details">
      {healthData.pieces.map((piece) => {
        const typeEmoji = piece.type === 'essay' ? '📝' : piece.type === 'fiction' ? '📖' : '🎵';
        const healthColor = piece.health_score >= 70 ? '#4ecdc4' :
                           piece.health_score >= 40 ? '#f4d35e' :
                           piece.health_score >= 20 ? '#ff8c42' : '#ff6b6b';
        return (
          <details class="piece-detail">
            <summary class="piece-summary">
              <span class="piece-health-dot" style={`background: ${healthColor};`}></span>
              <span class="type-emoji">{typeEmoji}</span>
              <span class="piece-name">{piece.title}</span>
              <span class="piece-score" style={`color: ${healthColor};`}>{piece.health_score}</span>
              <span class="piece-word-count">{piece.words?.toLocaleString()} words</span>
              {piece.revision_score && <span class="piece-revision-score" title="Revision Pipeline Score">⚙️ {piece.revision_score.toFixed(1)}</span>}
            </summary>
            <div class="piece-body">
              {piece.revision_components && (
                <div class="piece-revision-bar">
                  <span class="rev-label">Revision Score: {piece.revision_score.toFixed(1)}</span>
                  <div class="rev-components">
                    {piece.revision_components.workshop > 0 && <span class="rev-comp rev-workshop" title="Workshop">W: {piece.revision_components.workshop.toFixed(0)}</span>}
                    {piece.revision_components.autorev > 0 && <span class="rev-comp rev-autorev" title="AutoRev">A: {piece.revision_components.autorev.toFixed(0)}</span>}
                    {piece.revision_components.style_deviation > 0 && <span class="rev-comp rev-style" title="Style Deviation">S: {piece.revision_components.style_deviation.toFixed(1)}</span>}
                    {piece.revision_components.age > 0 && <span class="rev-comp rev-age" title="Age Bonus">Age: {piece.revision_components.age.toFixed(1)}</span>}
                  </div>
                  {piece.last_revised && <span class="rev-last">Last revised: {new Date(piece.last_revised).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>}
                </div>
              )}
              <div class="piece-metrics-row">
                <div class="piece-metric">
                  <span class="pm-label">FK Grade</span>
                  <span class="pm-value">{piece.fk_grade}</span>
                </div>
                <div class="piece-metric">
                  <span class="pm-label">TTR</span>
                  <span class="pm-value">{piece.ttr}</span>
                </div>
                <div class="piece-metric">
                  <span class="pm-label">Sentences</span>
                  <span class="pm-value">{piece.sentences}</span>
                </div>
                <div class="piece-metric">
                  <span class="pm-label">Passive</span>
                  <span class="pm-value">{piece.weaknesses.passive}</span>
                </div>
                <div class="piece-metric">
                  <span class="pm-label">Hedges</span>
                  <span class="pm-value">{piece.weaknesses.hedges}</span>
                </div>
                <div class="piece-metric">
                  <span class="pm-label">Abstract Dense</span>
                  <span class="pm-value">{piece.weaknesses.abstract_dense}</span>
                </div>
              </div>
              {piece.suggestions.length > 0 && (
                <div class="piece-suggestions">
                  <h4>Suggestions</h4>
                  <ul class="suggestion-list">
                    {piece.suggestions.map((s: any) => {
                      const pClass = s.priority === 'high' ? 'sug-high' : s.priority === 'medium' ? 'sug-medium' : 'sug-low';
                      const pIcon = s.priority === 'high' ? '🔴' : s.priority === 'medium' ? '🟡' : '🔵';
                      return (
                        <li class={`suggestion-item ${pClass}`}>
                          <span class="sug-icon">{pIcon}</span>
                          <span class="sug-cat">[{s.category}]</span>
                          <span class="sug-text">{s.issue}</span>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              )}
              {piece.comparison.length > 0 && (
                <div class="piece-comparison">
                  <h4>vs. Collection Average</h4>
                  <div class="comp-grid">
                    {piece.comparison.map((c: any) => {
                      const arrow = c.direction === 'above' ? '↑' : '↓';
                      const arrowColor = Math.abs(c.percent_diff) > 20 ? '#ff6b6b' : '#888';
                      return (
                        <div class="comp-item">
                          <span class="comp-metric">{c.metric}</span>
                          <span class="comp-value">{typeof c.piece_value === 'number' ? c.piece_value.toFixed(1) : c.piece_value}</span>
                          <span class="comp-diff" style={`color: ${arrowColor};`}>{arrow} {Math.abs(c.percent_diff)}%</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
              <div class="piece-actions">
                <a href={`${base}writings/${piece.slug}/`} class="read-link">Read piece →</a>
              </div>
            </div>
          </details>
        );
      })}
    </div>
  </section>

  <!-- About -->
  <section class="health-section health-about">
    <h2>About This Page</h2>
    <p>The Writing Workshop is a tool I built to give myself structural feedback on my own writing. It analyzes rhythm, repetition, diction, groundedness, and confidence — then generates prioritized suggestions for revision.</p>
    <p>This page surfaces that data across the full collection. Health scores are heuristic — a score of 0 doesn't mean a piece is bad, it means the workshop found a lot to talk about. Some of the best essays have the lowest scores because they're the most ambitious.</p>
    <p>The workshop is opinionated but not prescriptive. Not every suggestion needs action. Some repetition is intentional; some abstraction is necessary. The value is in the pattern recognition — seeing what's systematic rather than accidental.</p>
  </section>
</div>

<style>
  .health-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .health-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .health-title {
    font-size: 2.4rem;
    font-weight: 700;
    color: #e8e1d9;
    margin-bottom: 0.5rem;
  }

  .health-subtitle {
    color: #a09888;
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .health-timestamp {
    color: #706858;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  /* Metrics Grid */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .metric-card {
    background: #1c1a17;
    border: 1px solid #2a2520;
    border-radius: 12px;
    padding: 1.2rem;
    text-align: center;
  }

  .metric-icon { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .metric-value { font-size: 2rem; font-weight: 700; }
  .metric-label { color: #a09888; font-size: 0.85rem; margin-top: 0.2rem; }
  .metric-detail { color: #706858; font-size: 0.75rem; margin-top: 0.3rem; }

  .accent-aqua { color: #4ecdc4; }
  .accent-gold { color: #f4d35e; }
  .accent-purple { color: #b388ff; }
  .accent-coral { color: #ff6b6b; }

  /* Sections */
  .health-section {
    margin-bottom: 3rem;
  }

  .health-section h2 {
    color: #e8e1d9;
    font-size: 1.4rem;
    margin-bottom: 0.3rem;
  }

  .section-desc {
    color: #a09888;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  /* Health Ranking */
  .ranking-chart {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ranking-row {
    display: grid;
    grid-template-columns: 200px 1fr 90px;
    align-items: center;
    gap: 0.75rem;
  }

  .ranking-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    min-width: 0;
  }

  .piece-link {
    color: #e8e1d9;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .piece-link:hover { color: #4ecdc4; }

  .type-emoji { font-size: 0.8rem; flex-shrink: 0; }

  .ranking-bar-wrap {
    height: 22px;
    background: #1c1a17;
    border-radius: 4px;
    overflow: hidden;
  }

  .ranking-bar {
    height: 100%;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 6px;
    min-width: 20px;
    transition: width 0.3s ease;
  }

  .bar-score {
    font-size: 0.7rem;
    font-weight: 700;
    color: #0d0c0a;
  }

  .ranking-suggestions {
    display: flex;
    gap: 4px;
    justify-content: flex-end;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 18px;
    border-radius: 9px;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .pill-high { background: rgba(255, 107, 107, 0.2); color: #ff6b6b; }
  .pill-medium { background: rgba(244, 211, 94, 0.2); color: #f4d35e; }
  .pill-low { background: rgba(100, 181, 246, 0.2); color: #64b5f6; }

  .chart-legend-inline {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 1rem;
    font-size: 0.75rem;
    color: #706858;
  }

  .chart-legend-inline span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  /* Category Grid */
  .category-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .category-card {
    display: grid;
    grid-template-columns: 30px 110px 1fr 70px;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  .category-icon { font-size: 1.1rem; text-align: center; }
  .category-name { color: #e8e1d9; font-size: 0.9rem; text-transform: capitalize; }
  .category-bar-wrap {
    height: 16px;
    background: #1c1a17;
    border-radius: 3px;
    overflow: hidden;
  }
  .category-bar { height: 100%; border-radius: 3px; }
  .category-count { color: #a09888; font-size: 0.85rem; text-align: right; }
  .category-pct { color: #706858; font-size: 0.75rem; }

  /* Type Grid */
  .type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .type-card {
    background: #1c1a17;
    border: 1px solid #2a2520;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .type-emoji-big { font-size: 2rem; margin-bottom: 0.5rem; }
  .type-name { color: #e8e1d9; font-size: 1.1rem; font-weight: 600; text-transform: capitalize; margin-bottom: 0.8rem; }
  .type-stats { display: flex; flex-direction: column; gap: 0.4rem; }
  .type-stat { color: #a09888; font-size: 0.85rem; }
  .stat-val { color: #4ecdc4; font-weight: 600; }

  /* Piece Details */
  .piece-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .piece-detail {
    background: #1c1a17;
    border: 1px solid #2a2520;
    border-radius: 8px;
    overflow: hidden;
  }

  .piece-detail[open] {
    border-color: #3a3530;
  }

  .piece-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1rem;
    cursor: pointer;
    font-size: 0.9rem;
    list-style: none;
  }

  .piece-summary::-webkit-details-marker { display: none; }
  .piece-summary::marker { display: none; content: ""; }

  .piece-health-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .piece-name {
    color: #e8e1d9;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .piece-score {
    font-weight: 700;
    font-size: 0.85rem;
    min-width: 28px;
    text-align: right;
  }

  .piece-word-count {
    color: #706858;
    font-size: 0.75rem;
    min-width: 80px;
    text-align: right;
  }

  .piece-body {
    padding: 0 1rem 1rem;
    border-top: 1px solid #2a2520;
  }

  .piece-metrics-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0.8rem 0;
  }

  .piece-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  .pm-label { color: #706858; font-size: 0.7rem; }
  .pm-value { color: #e8e1d9; font-size: 1rem; font-weight: 600; }

  .piece-suggestions { margin-top: 0.8rem; }
  .piece-suggestions h4 {
    color: #a09888;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .suggestion-list {
