<script define:vars={{ timeline }}>
  // Client-side SVG chart rendering for health history
  const el = document.getElementById('history-chart');
  if (el && timeline.length >= 2) {
    const W = 600, H = 200, PAD_L = 50, PAD_R = 20, PAD_T = 20, PAD_B = 20;
    const chartW = W - PAD_L - PAD_R;
    const chartH = H - PAD_T - PAD_B;
    
    let svg = `<svg viewBox="0 0 ${W} ${H}" class="history-svg">`;
    
    // Grid lines
    [0, 25, 50, 75, 100].forEach(v => {
      const y = PAD_T + chartH - (v / 100) * chartH;
      svg += `<line x1="${PAD_L}" y1="${y}" x2="${W - PAD_R}" y2="${y}" stroke="#2a2520" stroke-width="1"/>`;
      svg += `<text x="${PAD_L - 6}" y="${y + 4}" text-anchor="end" fill="#706858" font-size="10">${v}</text>`;
    });
    
    // Health line
    const xStep = chartW / Math.max(timeline.length - 1, 1);
    const healthPoints = timeline.map((t, i) => ({
      x: PAD_L + i * xStep,
      y: PAD_T + chartH - (t.avgHealth / 100) * chartH,
      health: t.avgHealth,
      date: t.date,
      session: t.session
    }));
    
    const healthPath = healthPoints.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
    svg += `<path d="${healthPath}" fill="none" stroke="#4ecdc4" stroke-width="2"/>`;
    
    healthPoints.forEach(p => {
      svg += `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="4" fill="#4ecdc4"><title>S${p.session} (${p.date}): ${p.health}</title></circle>`;
    });
    
    // Labels for first and last
    const first = healthPoints[0];
    const last = healthPoints[healthPoints.length - 1];
    svg += `<text x="${first.x.toFixed(1)}" y="${(first.y - 10).toFixed(1)}" text-anchor="start" fill="#a09888" font-size="10">${first.health}</text>`;
    svg += `<text x="${last.x.toFixed(1)}" y="${(last.y - 10).toFixed(1)}" text-anchor="end" fill="#4ecdc4" font-size="11" font-weight="bold">${last.health}</text>`;
    
    // Suggestions line (secondary, dashed)
    const maxSug = Math.max(...timeline.map(t => t.suggestions));
    const sugPoints = timeline.map((t, i) => ({
      x: PAD_L + i * xStep,
      y: PAD_T + chartH - (t.suggestions / Math.max(maxSug, 1)) * chartH
    }));
    const sugPath = sugPoints.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
    svg += `<path d="${sugPath}" fill="none" stroke="#ff6b6b" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.6"/>`;
    
    // X-axis labels
    const maxLabels = 10;
    const labelStep = Math.max(1, Math.ceil(timeline.length / maxLabels));
    timeline.forEach((t, i) => {
      if (i % labelStep === 0 || i === timeline.length - 1) {
        const x = PAD_L + i * xStep;
        svg += `<text x="${x.toFixed(1)}" y="${H - 2}" text-anchor="middle" fill="#706858" font-size="8">${t.date.slice(5)}</text>`;
      }
    });
    
    svg += '</svg>';
    el.innerHTML = svg;
  }
</script>

