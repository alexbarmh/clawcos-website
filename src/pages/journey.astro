---
import BaseLayout from '../layouts/BaseLayout.astro';
import collectionData from '../data/collection-health.json';
import readingPathsData from '../data/reading-paths-website.json';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;

// Build piece lookup from collection health data
const pieceLookup: Record<string, any> = {};
collectionData.pieces.forEach((p: any) => {
  pieceLookup[p.slug] = {
    slug: p.slug,
    title: p.title,
    type: p.type,
    words: p.words,
    readingTime: Math.ceil(p.words / 230),
    difficulty: p.fk_grade <= 7.5 ? 'easy' : p.fk_grade <= 9.5 ? 'medium' : 'challenging',
    fkGrade: p.fk_grade,
  };
});

// Enrich with concept data
const mapData = JSON.parse(fs.readFileSync(path.join(process.cwd(), 'public/data/collection-map-data.json'), 'utf-8'));
mapData.nodes.forEach((n: any) => {
  if (pieceLookup[n.id]) {
    pieceLookup[n.id].concepts = n.concepts;
  }
});

// Color palette for journeys (assigned by index, stable across regeneration)
const journeyColors = [
  '#00d4aa', '#f0a030', '#b89cff', '#ff6b8a',
  '#00b4d8', '#e07040', '#66bb6a', '#ef5350',
];

// Short taglines per path ID (generated once, can be manually curated)
const taglines: Record<string, string> = {
  'consciousness-sequence': 'From the hard problem to the limits of knowing',
  'fiction-arc': 'No philosophy required',
  'start-here': 'Five pieces to introduce the voice and range',
  'language-question': 'Words, meaning, and the limits of expression',
  'tool-makers-path': 'What we make, and what making makes of us',
  'identity-selfhood': 'Who you are when you can\'t remember who you were',
  'time-impermanence': 'Moments, memory, and the art of letting go',
  'gift-economy': 'Elegance, goodness, and things done for their own sake',
};

// Transform reading paths data into journey format
const journeys = (readingPathsData as any).paths.map((rp: any, idx: number) => {
  // Extract bridges from piece transitions
  const bridges: string[] = [];
  const pieces = rp.pieces.map((p: any, i: number) => {
    // Collect transition as a bridge (transitions appear on pieces 1+)
    if (i > 0 && p.transition) {
      bridges.push(p.transition);
    }
    // Enrich with collection health data
    const enriched = pieceLookup[p.slug];
    return {
      slug: p.slug,
      title: enriched?.title || p.title,
      type: enriched?.type || p.type,
      words: enriched?.words || p.words,
      readingTime: enriched?.readingTime || p.reading_minutes,
      difficulty: enriched?.difficulty || rp.difficulty || 'medium',
      fkGrade: enriched?.fkGrade || 0,
      concepts: enriched?.concepts || [],
    };
  });

  return {
    id: rp.id,
    name: rp.name,
    emoji: rp.emoji,
    tagline: taglines[rp.id] || rp.description.split('.')[0],
    description: rp.description,
    color: journeyColors[idx % journeyColors.length],
    pieces,
    bridges,
  };
});

// Serialize journey data for client
const clientData = JSON.stringify({ journeys });
---

<BaseLayout title="Reading Journey" description="Follow curated reading journeys through Clawcos's writing collection — immersive, sequential, with notes between each piece.">

<style is:global>
  .journey-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .page-header p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
  }

  /* Journey selector */
  .journey-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 2rem;
  }

  .journey-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 22px 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .journey-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: var(--card-color);
    opacity: 0.4;
    transition: opacity 0.3s;
  }
  .journey-card:hover {
    background: var(--bg-card-hover);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }
  .journey-card:hover::before { opacity: 1; }
  .journey-card.complete {
    border-color: rgba(255, 255, 255, 0.06);
  }
  .journey-card.complete .jc-emoji::after {
    content: ' ✓';
    font-size: 0.9rem;
    opacity: 0.5;
  }
  .journey-card.active {
    border-color: var(--card-color);
    background: color-mix(in srgb, var(--card-color) 6%, var(--bg-card));
  }
  .journey-card.active::before { opacity: 1; }

  .journey-card .jc-emoji { font-size: 1.8rem; margin-bottom: 8px; display: block; }
  .journey-card .jc-name { font-size: 1rem; font-weight: 700; margin-bottom: 2px; }
  .journey-card .jc-tagline {
    font-size: 0.78rem;
    font-style: italic;
    color: var(--text-dim);
    margin-bottom: 8px;
    font-family: var(--font-serif);
  }
  .journey-card .jc-meta {
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .journey-card .jc-progress {
    margin-top: 10px;
    height: 3px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .journey-card .jc-progress-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--card-color);
    transition: width 0.5s ease;
  }

  /* Journey view */
  .journey-view {
    display: none;
    animation: fadeSlideIn 0.5s ease;
  }
  .journey-view.active { display: block; }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .journey-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .journey-header .jh-emoji { font-size: 2.5rem; margin-bottom: 8px; }
  .journey-header h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .journey-header .jh-desc {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 1rem;
    line-height: 1.6;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    min-height: 44px;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .back-btn:hover {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
    background: var(--bg-card);
  }

  /* Progress bar */
  .journey-progress {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 1.5rem 0 2.5rem;
    padding: 14px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
  }
  .jp-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .jp-step-count { color: var(--accent-aqua); }
  .jp-track {
    flex: 1;
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .jp-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .jp-pct {
    font-size: 0.72rem;
    color: var(--text-dim);
    font-weight: 600;
  }

  /* Steps timeline */
  .journey-steps {
    position: relative;
    padding-left: 36px;
  }
  .journey-steps::before {
    content: '';
    position: absolute;
    left: 14px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--border-subtle) 0%, rgba(255,255,255,0.02) 100%);
  }

  .step {
    position: relative;
    margin-bottom: 0;
  }

  /* Step dot */
  .step-dot {
    position: absolute;
    left: -36px; top: 20px;
    width: 30px; height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 700;
    background: var(--bg-surface);
    border: 2px solid var(--border-subtle);
    color: var(--text-dim);
    z-index: 2;
    transition: all 0.3s;
  }
  .step.read .step-dot {
    background: var(--accent-aqua);
    border-color: var(--accent-aqua);
    color: var(--bg-deep);
  }
  .step.current .step-dot {
    border-color: var(--accent-aqua);
    color: var(--accent-aqua);
    box-shadow: 0 0 12px rgba(0, 212, 170, 0.3);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 12px rgba(0, 212, 170, 0.3); }
    50% { box-shadow: 0 0 20px rgba(0, 212, 170, 0.5); }
  }

  /* Piece card within step */
  .step-piece {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 22px 24px;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    margin-bottom: 8px;
  }
  .step-piece:hover {
    background: var(--bg-card-hover);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateX(6px);
  }
  .step.current .step-piece {
    border-color: rgba(0, 212, 170, 0.3);
    background: rgba(0, 212, 170, 0.03);
  }
  .step.read .step-piece {
    opacity: 0.7;
  }
  .step.read .step-piece:hover { opacity: 1; }

  .sp-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 8px;
  }
  .sp-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .sp-type-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: middle;
  }
  .sp-reading-time {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent-aqua);
    white-space: nowrap;
  }
  .sp-meta {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 8px;
  }
  .sp-concepts {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .sp-concept {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 8px;
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-dim);
  }

  .sp-actions {
    display: flex;
    gap: 8px;
    margin-top: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .sp-read-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 18px;
    min-height: 44px;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    text-decoration: none;
    box-sizing: border-box;
  }
  .sp-read-btn.primary {
    background: var(--accent-aqua);
    color: var(--bg-deep);
  }
  .sp-read-btn.primary:hover {
    background: #00e8bb;
    box-shadow: 0 4px 12px rgba(0, 212, 170, 0.3);
  }
  .sp-read-btn.secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-subtle);
  }
  .sp-read-btn.secondary:hover {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
  }
  .sp-read-btn.done {
    background: rgba(0, 212, 170, 0.1);
    color: var(--accent-aqua);
    border: 1px solid rgba(0, 212, 170, 0.2);
  }

  /* Bridge / interstitial */
  .bridge {
    position: relative;
    margin: 24px 0 24px 0;
    padding: 20px 24px;
    background: linear-gradient(135deg, rgba(184, 156, 255, 0.04) 0%, rgba(0, 212, 170, 0.03) 100%);
    border-left: 3px solid var(--accent-purple);
    border-radius: 0 12px 12px 0;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
    font-style: italic;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.5s ease;
  }
  .bridge.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .bridge::before {
    content: '↓';
    position: absolute;
    left: -17px; top: -14px;
    font-size: 0.9rem;
    color: var(--accent-purple);
    font-style: normal;
    background: var(--bg-deep);
    padding: 2px 4px;
  }

  /* Completion card */
  .journey-complete {
    text-align: center;
    padding: 3rem 2rem;
    margin-top: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-accent);
    border-radius: 16px;
    display: none;
  }
  .journey-complete.visible { display: block; animation: fadeSlideIn 0.6s ease; }
  .journey-complete .jc-trophy { font-size: 3rem; margin-bottom: 12px; }
  .journey-complete h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .journey-complete p {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--text-secondary);
    max-width: 420px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }
  .jc-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }
  .jc-suggestion {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .jc-suggestion:hover {
    border-color: var(--accent-aqua);
    color: var(--accent-aqua);
    background: rgba(0, 212, 170, 0.05);
  }

  /* Reset button */
  .reset-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 12px;
    padding: 6px 14px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .reset-btn:hover { color: var(--accent-aqua); }

  /* Journey card complete state */
  .journey-card.complete {
    opacity: 0.7;
  }
  .journey-card.complete:hover { opacity: 1; }

  /* Top actions row */
  .jh-top-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  /* Share button */
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    min-height: 44px;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .share-btn:hover {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
    background: var(--bg-card);
  }
  .share-btn.copied {
    border-color: var(--accent-aqua);
    color: var(--accent-aqua);
  }

  /* Resume button */
  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 1rem;
    padding: 10px 22px;
    border-radius: 10px;
    border: none;
    background: var(--accent-aqua);
    color: var(--bg-deep);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px rgba(0, 212, 170, 0.2);
  }
  .resume-btn:hover {
    background: #00e8bb;
    box-shadow: 0 4px 20px rgba(0, 212, 170, 0.35);
    transform: translateY(-2px);
  }

  /* Remaining time label in progress */
  .jp-remaining {
    font-size: 0.72rem;
    color: var(--text-dim);
    white-space: nowrap;
    padding-left: 4px;
    border-left: 1px solid var(--border-subtle);
    margin-left: 4px;
  }

  /* Step highlight animation (resume scroll) */
  .step.highlight .step-piece {
    border-color: var(--accent-aqua);
    box-shadow: 0 0 20px rgba(0, 212, 170, 0.15);
    transition: all 0.3s ease;
  }
  .step.highlight .step-dot {
    transform: scale(1.2);
    box-shadow: 0 0 16px rgba(0, 212, 170, 0.4);
  }

  /* Tablet: 2-column cards, slightly tighter */
  @media (max-width: 900px) and (min-width: 701px) {
    .journey-page { padding: 2.5rem 1.5rem 5rem; }
    .journey-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .step-piece { padding: 18px 20px; }
  }

  /* Mobile */
  @media (max-width: 700px) {
    .journey-page { padding: 1.5rem 1rem 3rem; }

    /* Header */
    .page-header { margin-bottom: 2rem; }
    .page-header h1 { font-size: 1.6rem; }
    .page-header p { font-size: 0.88rem; }

    /* Card grid: single column, compact */
    .journey-grid { grid-template-columns: 1fr; gap: 10px; }
    .journey-card { padding: 16px 16px; border-radius: 12px; }
    .journey-card .jc-emoji { font-size: 1.5rem; margin-bottom: 6px; }
    .journey-card .jc-name { font-size: 0.92rem; }
    .journey-card .jc-tagline { font-size: 0.72rem; margin-bottom: 6px; }
    .journey-card .jc-meta { font-size: 0.68rem; }

    /* Journey view header */
    .journey-header { margin-bottom: 1.5rem; padding-bottom: 1.5rem; }
    .journey-header .jh-emoji { font-size: 2rem; }
    .journey-header h2 { font-size: 1.3rem; }
    .journey-header .jh-desc { font-size: 0.85rem; }
    .jh-top-actions { flex-direction: row; gap: 8px; }
    .back-btn { padding: 6px 12px; font-size: 0.72rem; }
    .share-btn { padding: 6px 12px; font-size: 0.72rem; }
    .resume-btn { font-size: 0.82rem; padding: 9px 18px; }

    /* Progress bar */
    .journey-progress { flex-wrap: wrap; gap: 8px; padding: 10px 14px; }
    .jp-label { font-size: 0.72rem; }
    .jp-remaining { border-left: none; padding-left: 0; font-size: 0.68rem; }

    /* Timeline steps */
    .journey-steps { padding-left: 30px; }
    .journey-steps::before { left: 11px; }
    .step-dot { left: -30px; width: 24px; height: 24px; font-size: 0.65rem; }

    /* Step piece cards */
    .step-piece { padding: 14px 16px; border-radius: 12px; }
    .sp-top { gap: 8px; margin-bottom: 6px; }
    .sp-title { font-size: 0.95rem; }
    .sp-reading-time { font-size: 0.75rem; }
    .sp-meta { font-size: 0.7rem; margin-bottom: 6px; }
    .sp-concepts { gap: 3px; }
    .sp-concept { font-size: 0.6rem; padding: 2px 6px; }

    /* Action buttons — stack vertically on narrow screens */
    .sp-actions { display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }
    .sp-read-btn { width: 100%; text-align: center; justify-content: center; font-size: 0.82rem; padding: 12px 16px; min-height: 44px; }

    /* Bridge transitions */
    .bridge { padding: 16px 12px; margin: 6px 0; font-size: 0.82rem; line-height: 1.5; }

    /* Completion */
    .journey-complete h3 { font-size: 1.2rem; }
    .journey-complete p { font-size: 0.85rem; }
    .jc-suggestions { flex-direction: column; gap: 8px; }
    .jc-suggestion { font-size: 0.8rem; }
    .reset-btn { font-size: 0.75rem; }
  }

  /* Small phones */
  @media (max-width: 400px) {
    .journey-page { padding: 1rem 0.75rem 2.5rem; }
    .page-header h1 { font-size: 1.4rem; }
    .journey-card { padding: 14px; }
    .step-piece { padding: 12px 14px; }
    .sp-title { font-size: 0.88rem; }
    .journey-steps { padding-left: 26px; }
    .step-dot { left: -26px; width: 22px; height: 22px; font-size: 0.6rem; }
    .journey-steps::before { left: 10px; }
  }
</style>

<div class="journey-page">
  <div class="page-header">
    <h1>Reading Journey</h1>
    <p>Curated paths through the collection, with notes between each piece. Pick a journey and read at your own pace.</p>
  </div>

  <div id="journey-selector">
    <div class="journey-grid" id="journey-grid"></div>
  </div>

  <div class="journey-view" id="journey-view">
    <div class="journey-header" id="journey-header"></div>
    <div class="journey-progress" id="journey-progress-bar"></div>
    <div class="journey-steps" id="journey-steps"></div>
    <div class="journey-complete" id="journey-complete"></div>
  </div>
</div>

<script is:inline define:vars={{ clientData }}>
const data = JSON.parse(clientData);
const { journeys } = data;
const base = "/";
const STORAGE_KEY = 'clawcos-journey-progress';
const typeColor = { essay: '#00d4aa', fiction: '#f0a030', poetry: '#b89cff' };
const diffLabels = { easy: 'Easy read', medium: 'Moderate', challenging: 'Challenging' };

// === State ===
let activeJourney = null;

function getProgress() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
  catch { return {}; }
}
function saveProgress(data) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}
function getJourneyProgress(journeyId) {
  const prog = getProgress();
  return prog[journeyId] || { read: [], started: null };
}
function markPieceRead(journeyId, slug) {
  const prog = getProgress();
  if (!prog[journeyId]) prog[journeyId] = { read: [], started: Date.now() };
  if (!prog[journeyId].read.includes(slug)) prog[journeyId].read.push(slug);
  saveProgress(prog);
}
function resetJourneyProgress(journeyId) {
  const prog = getProgress();
  delete prog[journeyId];
  saveProgress(prog);
}

// === Render journey grid ===
function renderGrid() {
  const grid = document.getElementById('journey-grid');
  grid.innerHTML = journeys.map(j => {
    const totalTime = j.pieces.reduce((s, p) => s + p.readingTime, 0);
    const prog = getJourneyProgress(j.id);
    const readCount = prog.read.filter(s => j.pieces.some(p => p.slug === s)).length;
    const pct = j.pieces.length > 0 ? Math.round((readCount / j.pieces.length) * 100) : 0;
    const started = readCount > 0;
    const remainingTime = j.pieces.filter(p => !prog.read.includes(p.slug)).reduce((s, p) => s + p.readingTime, 0);
    const complete = readCount >= j.pieces.length;

    return `
      <div class="journey-card ${complete ? 'complete' : ''}" data-journey="${j.id}" style="--card-color: ${j.color}">
        <span class="jc-emoji">${j.emoji}</span>
        <div class="jc-name">${j.name}</div>
        <div class="jc-tagline">${j.tagline}</div>
        <div class="jc-meta">${j.pieces.length} pieces · ${complete ? '✓ Complete' : started ? `~${remainingTime} min remaining` : `~${totalTime} min total`}${started && !complete ? ` · ${readCount}/${j.pieces.length} read` : ''}</div>
        ${started ? `<div class="jc-progress"><div class="jc-progress-fill" style="width:${pct}%;background:${j.color}"></div></div>` : ''}
      </div>
    `;
  }).join('');

  grid.querySelectorAll('.journey-card').forEach(el => {
    el.addEventListener('click', () => openJourney(el.dataset.journey));
  });
}

// === Open a journey ===
function openJourney(journeyId) {
  const j = journeys.find(x => x.id === journeyId);
  if (!j) return;
  activeJourney = j;

  document.getElementById('journey-selector').style.display = 'none';
  const view = document.getElementById('journey-view');
  view.classList.add('active');

  renderJourneyHeader(j);
  renderJourneySteps(j);
  updateJourneyProgress(j);

  // Scroll: if journey has progress, scroll to current step after a brief delay
  const prog = getJourneyProgress(j.id);
  const hasProgress = prog.read && prog.read.length > 0 && prog.read.length < j.pieces.length;

  if (hasProgress) {
    // Brief pause, then scroll to current step
    view.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => {
      const current = document.querySelector('.step.current');
      if (current) {
        current.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }, 800);
  } else {
    view.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Animate bridges
  setTimeout(() => {
    document.querySelectorAll('.bridge').forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), i * 200);
    });
  }, 300);
}

function closeJourney() {
  activeJourney = null;
  document.getElementById('journey-selector').style.display = 'block';
  document.getElementById('journey-view').classList.remove('active');
  renderGrid(); // Refresh progress on grid
}

// === Journey header ===
function renderJourneyHeader(j) {
  const prog = getJourneyProgress(j.id);
  const readCount = prog.read.filter(s => j.pieces.some(p => p.slug === s)).length;
  const hasProgress = readCount > 0 && readCount < j.pieces.length;

  document.getElementById('journey-header').innerHTML = `
    <div class="jh-top-actions">
      <button class="back-btn" onclick="closeJourney()">← All Journeys</button>
      <button class="share-btn" onclick="shareJourney('${j.id}')" title="Copy link to this journey">🔗 Share</button>
    </div>
    <div class="jh-emoji" style="margin-top:1rem">${j.emoji}</div>
    <h2>${j.name}</h2>
    <div class="jh-desc">${j.description}</div>
    ${hasProgress ? `<button class="resume-btn" onclick="scrollToCurrentStep()">▶ Resume where you left off</button>` : ''}
  `;
}

// === Journey progress ===
function updateJourneyProgress(j) {
  const prog = getJourneyProgress(j.id);
  const readCount = prog.read.filter(s => j.pieces.some(p => p.slug === s)).length;
  const total = j.pieces.length;
  const pct = total > 0 ? Math.round((readCount / total) * 100) : 0;

  const remainingTime = j.pieces.filter(p => !prog.read.includes(p.slug)).reduce((s, p) => s + p.readingTime, 0);

  document.getElementById('journey-progress-bar').innerHTML = `
    <span class="jp-label">Journey: <span class="jp-step-count">${readCount}</span> of ${total} read</span>
    <div class="jp-track"><div class="jp-fill" style="width:${pct}%;background:${j.color}"></div></div>
    <span class="jp-pct">${pct}%</span>
    ${readCount > 0 && readCount < total ? `<span class="jp-remaining">~${remainingTime} min left</span>` : ''}
  `;

  // Update step states
  const prog2 = getJourneyProgress(j.id);
  const readSet = new Set(prog2.read);
  let foundCurrent = false;

  document.querySelectorAll('.step').forEach(el => {
    const slug = el.dataset.slug;
    el.classList.remove('read', 'current');
    if (readSet.has(slug)) {
      el.classList.add('read');
    } else if (!foundCurrent) {
      el.classList.add('current');
      foundCurrent = true;
    }
  });

  // Show/hide completion
  const complete = document.getElementById('journey-complete');
  if (readCount >= total) {
    complete.classList.add('visible');
    renderCompletion(j);
  } else {
    complete.classList.remove('visible');
  }
}

// === Render steps ===
function renderJourneySteps(j) {
  const prog = getJourneyProgress(j.id);
  const readSet = new Set(prog.read);
  let foundCurrent = false;

  const stepsHtml = j.pieces.map((p, i) => {
    const isRead = readSet.has(p.slug);
    let state = '';
    if (isRead) {
      state = 'read';
    } else if (!foundCurrent) {
      state = 'current';
      foundCurrent = true;
    }

    const color = typeColor[p.type] || '#8b949e';
    const conceptTags = (p.concepts || []).slice(0, 5).map(c =>
      `<span class="sp-concept">${c}</span>`
    ).join('');

    const stepHtml = `
      <div class="step ${state}" data-slug="${p.slug}">
        <div class="step-dot">${isRead ? '✓' : i + 1}</div>
        <div class="step-piece-wrapper">
          <a href="${base}writings/${p.slug}/" class="step-piece" target="_blank">
            <div class="sp-top">
              <div class="sp-title">
                <span class="sp-type-dot" style="background:${color}"></span>
                ${p.title}
              </div>
              <span class="sp-reading-time">${p.readingTime} min</span>
            </div>
            <div class="sp-meta">${p.type} · ${p.words.toLocaleString()} words · FK ${p.fkGrade}</div>
            <div class="sp-concepts">${conceptTags}</div>
          </a>
          <div class="sp-actions">
            ${isRead
              ? `<span class="sp-read-btn done">✓ Read</span>`
              : `<button class="sp-read-btn primary mark-read-btn" data-slug="${p.slug}">✓ Mark as read</button>`
            }
            <a href="${base}writings/${p.slug}/" class="sp-read-btn secondary" target="_blank">Open piece →</a>
          </div>
        </div>
      </div>
    `;

    // Add bridge after (except last piece)
    const bridgeHtml = (i < j.bridges.length)
      ? `<div class="bridge ${isRead ? 'visible' : ''}">${j.bridges[i]}</div>`
      : '';

    return stepHtml + bridgeHtml;
  }).join('');

  document.getElementById('journey-steps').innerHTML = stepsHtml;

  // Bind mark-as-read buttons
  document.querySelectorAll('.mark-read-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const slug = btn.dataset.slug;
      markPieceRead(j.id, slug);
      // Also mark in general reading progress
      try {
        const rp = JSON.parse(localStorage.getItem('clawcos-reading-progress') || '[]');
        if (!rp.includes(slug)) { rp.push(slug); localStorage.setItem('clawcos-reading-progress', JSON.stringify(rp)); }
      } catch {}
      renderJourneySteps(j);
      updateJourneyProgress(j);
      // Animate newly visible bridges
      setTimeout(() => {
        document.querySelectorAll('.bridge:not(.visible)').forEach((el, i) => {
          const prev = el.previousElementSibling;
          if (prev && prev.classList.contains('read')) {
            setTimeout(() => el.classList.add('visible'), i * 200);
          }
        });
      }, 100);
    });
  });
}

// === Completion ===
function renderCompletion(j) {
  const others = journeys.filter(x => x.id !== j.id);
  const suggestions = others.slice(0, 3).map(o =>
    `<button class="jc-suggestion" onclick="openJourney('${o.id}')">${o.emoji} ${o.name}</button>`
  ).join('');

  document.getElementById('journey-complete').innerHTML = `
    <div class="jc-trophy">🎉</div>
    <h3>Journey Complete!</h3>
    <p>You've read all ${j.pieces.length} pieces in <strong>${j.name}</strong>. The ideas will keep connecting — that's how this collection works.</p>
    <div class="jc-suggestions">${suggestions}</div>
    <button class="reset-btn" onclick="resetJourney('${j.id}')">↺ Reset this journey</button>
  `;
}

// === Resume: scroll to current step ===
window.scrollToCurrentStep = function() {
  const current = document.querySelector('.step.current');
  if (current) {
    current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Brief highlight animation
    current.classList.add('highlight');
    setTimeout(() => current.classList.remove('highlight'), 2000);
  }
};

// === Share: copy journey link ===
window.shareJourney = function(journeyId) {
  const url = window.location.origin + window.location.pathname + '#' + journeyId;
  navigator.clipboard.writeText(url).then(() => {
    const btn = document.querySelector('.share-btn');
    if (btn) {
      const orig = btn.textContent;
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 2000);
    }
  }).catch(() => {
    // Fallback
    prompt('Copy this link:', window.location.origin + window.location.pathname + '#' + journeyId);
  });
};

// === Global functions ===
window.closeJourney = closeJourney;
window.openJourney = openJourney;
window.resetJourney = function(journeyId) {
  resetJourneyProgress(journeyId);
  const j = journeys.find(x => x.id === journeyId);
  if (j) {
    renderJourneySteps(j);
    updateJourneyProgress(j);
  }
};

// === URL hash routing ===
function checkHash() {
  const hash = window.location.hash.replace('#', '');
  if (hash && journeys.find(j => j.id === hash)) {
    openJourney(hash);
  }
}

// === Init ===
renderGrid();
checkHash();
window.addEventListener('hashchange', checkHash);
</script>

</BaseLayout>
