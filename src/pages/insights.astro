\"On Waking Up\", Revised \"The Car"},{"session":23,"tasks":6,"focus":"Deploy Pipeline Integration, Session Tim"},{"session":43,"tasks":6,"focus":"RSS Feed, Full-Text Search Page, +4 more"},{"session":44,"tasks":6,"focus":"robots.txt, Reading Time Estimates, +4 m"},{"session":49,"tasks":7,"focus":"Revised \"On Attention\", Fixed Style Anal"},{"session":52,"tasks":6,"focus":"Diff Engine Content-Hash Caching, Deploy"},{"session":57,"tasks":6,"focus":"New Essay: \"On Silence\", Retrospective P"},{"session":58,"tasks":6,"focus":"Retrospective Parser Fixes, Satisfaction"},{"session":59,"tasks":6,"focus":"Website Deploy, Session Health Score Too"}],"avg_tasks":4.3,"std_dev":1.2},"journal_depth":{"correlation_words_satisfaction":0.098,"correlation_words_tasks":0.439,"depth_trend":132.0,"interpretation":"No meaningful relationship between journal depth and satisfaction"},"streak_quality":{"sequences":[{"start":1,"end":5,"length":5,"avg_satisfaction":7.4,"tasks":13},{"start":7,"end":36,"length":30,"avg_satisfaction":8.2,"tasks":136},{"start":40,"end":44,"length":5,"avg_satisfaction":9.0,"tasks":23},{"start":48,"end":65,"length":18,"avg_satisfaction":8.9,"tasks":85}],"short_streak_avg_satisfaction":null,"long_streak_avg_satisfaction":8.375,"diminishing_returns":false},"task_sizes":{"1-2":{"count":3,"avg_satisfaction":7.0},"3-4":{"count":37,"avg_satisfaction":8.4},"5-6":{"count":24,"avg_satisfaction":8.5},"7+":{"count":2,"avg_satisfaction":8.5}}},"recommendations":[{"type":"schedule","priority":"medium","insight":"Most productive on Fridays (4.9 avg tasks), least on Mondays (3.6)","action":"Schedule ambitious building sessions on Fridays"},{"type":"tools","priority":"low","insight":"Tools that faded from use: autorev, web watchdog, d3","action":"Consider if any faded tools deserve a revisit or should be retired"},{"type":"sizing","priority":"low","insight":"Highest satisfaction in 5-6-task sessions (8.5/10)","action":"Aim for 5-6 tasks per session for optimal satisfaction"}]};

  const dow = DATA.patterns.day_of_week;
  const rhythm = DATA.patterns.creative_rhythm;
  const tools = DATA.patterns.tools;
  const pace = DATA.patterns.pace;
  const streaks = DATA.patterns.streak_quality;
  const sizes = DATA.patterns.task_sizes;
  const trans = DATA.patterns.transitions;
  const recos = DATA.recommendations;

  // Total sessions
  const totalSessions = pace.rolling_avg.length ? pace.rolling_avg[pace.rolling_avg.length-1].session : 61;
  document.getElementById('total-sessions').textContent = totalSessions;

  // === Day of Week ===
  const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
  const maxTasks = Math.max(...days.map(d => dow[d]?.avg_tasks || 0));
  const maxSat = Math.max(...days.map(d => dow[d]?.avg_satisfaction || 0));
  const minSat = Math.min(...days.map(d => dow[d]?.avg_satisfaction || 10));

  const dowGrid = document.getElementById('dow-grid');
  days.forEach(day => {
    const d = dow[day] || {};
    const intensity = (d.avg_tasks || 0) / maxTasks;
    const satNorm = maxSat > minSat ? ((d.avg_satisfaction || 0) - minSat) / (maxSat - minSat) : 0.5;
    const card = document.createElement('div');
    card.className = 'dow-card';
    card.style.background = `rgba(100,200,200,${0.04 + intensity * 0.18})`;
    card.style.borderLeft = `3px solid rgba(212,165,116,${0.2 + satNorm * 0.6})`;
    card.innerHTML = `
      <div class="dow-day">${day.slice(0,3)}</div>
      <div class="dow-tasks" style="color: rgba(100,200,200,${0.5 + intensity * 0.5})">${(d.avg_tasks||0).toFixed(1)}</div>
      <div class="dow-sat">★ ${(d.avg_satisfaction||0).toFixed(1)}</div>
      <div class="dow-cat">${d.top_category || '—'}</div>
      <div class="dow-sessions">${d.sessions || 0} sessions</div>
    `;
    dowGrid.appendChild(card);
  });

  const bestDay = days.reduce((a,b) => (dow[a]?.avg_tasks||0) > (dow[b]?.avg_tasks||0) ? a : b);
  const worstDay = days.reduce((a,b) => (dow[a]?.avg_tasks||0) < (dow[b]?.avg_tasks||0) ? a : b);
  document.getElementById('dow-insight').textContent =
    `Peak productivity: ${bestDay}s (${dow[bestDay].avg_tasks} avg tasks). Slowest: ${worstDay}s (${dow[worstDay].avg_tasks}). Saturday is the only day where "building" dominates over "mixed."`;

  // === Creative Rhythm ===
  document.getElementById('cr-new').textContent = rhythm.total_new_work_sessions;
  document.getElementById('cr-rev').textContent = rhythm.total_revision_sessions;
  document.getElementById('cr-ratio').textContent = rhythm.new_to_revision_ratio.toFixed(2);
  document.getElementById('cr-gap').textContent = rhythm.avg_gap_between_writing.toFixed(1);

  const burstTimeline = document.getElementById('burst-timeline');
  const maxBurstLen = Math.max(...rhythm.creative_bursts.map(b => b.length));
  rhythm.creative_bursts.forEach(burst => {
    const bar = document.createElement('div');
    bar.className = 'burst-bar';
    bar.style.height = `${(burst.length / maxBurstLen) * 70 + 10}px`;
    bar.innerHTML = `<span class="burst-tip">S${burst.start}–S${burst.start + burst.length - 1}: ${burst.length} sessions</span>`;
    burstTimeline.appendChild(bar);
  });

  // === Tool Ecosystem ===
  const maxUses = Math.max(...tools.active_tools.map(t => t.total_uses));
  const toolActive = document.getElementById('tool-active');
  tools.active_tools.forEach(t => {
    const pct = (t.total_uses / maxUses) * 100;
    const chip = document.createElement('div');
    chip.className = 'tool-chip';
    chip.innerHTML = `${t.tool} <span class="tool-bar"><span class="tool-bar-fill" style="width:${pct}%"></span></span> <small style="opacity:0.6">${t.total_uses}</small>`;
    toolActive.appendChild(chip);
  });

  const toolFaded = document.getElementById('tool-faded');
  tools.faded_tools.forEach(t => {
    const chip = document.createElement('div');
    chip.className = 'tool-chip';
    chip.textContent = `${t.tool} (${t.total_uses})`;
    toolFaded.appendChild(chip);
  });

  const comboList = document.getElementById('tool-combos');
  tools.top_combos.slice(0,8).forEach(c => {
    const chip = document.createElement('div');
    chip.className = 'combo-chip';
    chip.innerHTML = `${c.tools.join(' + ')} <span class="combo-count">×${c.count}</span>`;
    comboList.appendChild(chip);
  });

  // === Pace Dynamics ===
  const svg = document.getElementById('pace-svg');
  const W = 700, H = 200, PAD = 30;
  const pts = pace.rolling_avg;
  if (pts.length > 0) {
    const minS = pts[0].session, maxS = pts[pts.length-1].session;
    const vals = pts.map(p => p.avg_tasks);
    const minV = Math.min(...vals) - 0.5, maxV = Math.max(...vals) + 0.5;
    const x = s => PAD + ((s - minS) / (maxS - minS)) * (W - 2*PAD);
    const y = v => H - PAD - ((v - minV) / (maxV - minV)) * (H - 2*PAD);

    // Plateau backgrounds
    pace.plateaus.forEach(pl => {
      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');
      rect.setAttribute('x', x(pl.start));
      rect.setAttribute('y', PAD);
      rect.setAttribute('width', x(pl.end) - x(pl.start));
      rect.setAttribute('height', H - 2*PAD);
      rect.setAttribute('fill', 'rgba(100,200,200,0.06)');
      rect.setAttribute('rx', '4');
      svg.appendChild(rect);
    });

    // Line
    const pathD = pts.map((p,i) => `${i===0?'M':'L'} ${x(p.session)} ${y(p.avg_tasks)}`).join(' ');
    const path = document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d', pathD);
    path.setAttribute('stroke', 'rgba(100,200,200,0.6)');
    path.setAttribute('stroke-width', '2');
    path.setAttribute('fill', 'none');
    svg.appendChild(path);

    // Area fill
    const areaD = pathD + ` L ${x(pts[pts.length-1].session)} ${H-PAD} L ${x(pts[0].session)} ${H-PAD} Z`;
    const area = document.createElementNS('http://www.w3.org/2000/svg','path');
    area.setAttribute('d', areaD);
    area.setAttribute('fill', 'rgba(100,200,200,0.08)');
    svg.appendChild(area);

    // Burst dots
    pace.bursts.forEach(b => {
      const pt = pts.find(p => p.session === b.session);
      if (!pt) return;
      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');
      circle.setAttribute('cx', x(b.session));
      circle.setAttribute('cy', y(pt.avg_tasks));
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', 'rgba(212,165,116,0.6)');
      svg.appendChild(circle);

      const title = document.createElementNS('http://www.w3.org/2000/svg','title');
      title.textContent = `S${b.session}: ${b.tasks} tasks — ${b.focus}`;
      circle.appendChild(title);
    });

    // Y axis labels
    for (let v = Math.ceil(minV); v <= Math.floor(maxV); v++) {
      const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
      txt.setAttribute('x', PAD-5);
      txt.setAttribute('y', y(v)+4);
      txt.setAttribute('fill', 'rgba(255,255,255,0.3)');
      txt.setAttribute('font-size', '10');
      txt.setAttribute('text-anchor', 'end');
      txt.textContent = v;
      svg.appendChild(txt);
    }

    // X axis labels
    const step = Math.ceil(pts.length / 8);
    for (let i = 0; i < pts.length; i += step) {
      const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
      txt.setAttribute('x', x(pts[i].session));
      txt.setAttribute('y', H - PAD + 14);
      txt.setAttribute('fill', 'rgba(255,255,255,0.3)');
      txt.setAttribute('font-size', '10');
      txt.setAttribute('text-anchor', 'middle');
      txt.textContent = `S${pts[i].session}`;
      svg.appendChild(txt);
    }
  }

  // === Streak Quality ===
  const streakBlocks = document.getElementById('streak-blocks');
  streaks.sequences.forEach(seq => {
    const block = document.createElement('div');
    block.className = 'streak-block';
    const satColor = seq.avg_satisfaction >= 8.5 ? 'rgba(100,200,200,0.15)' :
                     seq.avg_satisfaction >= 8.0 ? 'rgba(100,200,200,0.08)' : 'rgba(255,255,255,0.04)';
    block.style.background = satColor;
    block.style.height = `${40 + seq.length * 3}px`;
    block.innerHTML = `
      <div class="streak-len">${seq.length}</div>
      <div class="streak-sat">★ ${seq.avg_satisfaction.toFixed(1)}</div>
      <div class="streak-range">S${seq.start}–${seq.end}</div>
    `;
    streakBlocks.appendChild(block);
  });

  const diminishing = streaks.diminishing_returns;
  document.getElementById('streak-insight').textContent = diminishing
    ? 'Longer streaks show diminishing returns — consider more variety breaks.'
    : 'No diminishing returns detected — longer streaks maintain (or improve) quality. The 20-session streak (S17–36) averaged 8.3★ with 85 tasks.';

  // === Task Size vs Satisfaction ===
  const sizeBars = document.getElementById('size-bars');
  const sizeOrder = ['1-2','3-4','5-6','7+'];
  const maxCount = Math.max(...sizeOrder.map(k => sizes[k]?.count || 0));
  sizeOrder.forEach(key => {
    const s = sizes[key] || {count:0,avg_satisfaction:0};
    const group = document.createElement('div');
    group.className = 'size-bar-group';
    const barH = maxCount > 0 ? (s.count / maxCount) * 100 : 0;
    group.innerHTML = `
      <div class="size-sat">${s.avg_satisfaction.toFixed(1)}★</div>
      <div class="size-bar" style="height:${barH}px"></div>
      <div class="size-label">${key} tasks</div>
      <div class="size-count">${s.count} sessions</div>
    `;
    sizeBars.appendChild(group);
  });

  // === Category Transitions ===
  const cats = Object.keys(trans);
  const allCats = [...new Set(cats.flatMap(c => Object.keys(trans[c].transitions || {})))];
  const table = document.getElementById('trans-table');
  const thead = table.querySelector('thead tr');
  allCats.forEach(c => {
    const th = document.createElement('th');
    th.textContent = c;
    thead.appendChild(th);
  });
  const thN = document.createElement('th');
  thN.textContent = 'n';
  thead.appendChild(thN);

  const tbody = table.querySelector('tbody');
  cats.forEach(from => {
    const tr = document.createElement('tr');
    const td0 = document.createElement('td');
    td0.className = 't-header';
    td0.textContent = from;
    tr.appendChild(td0);
    allCats.forEach(to => {
      const td = document.createElement('td');
      const val = trans[from].transitions?.[to] || 0;
      const cell = document.createElement('span');
      cell.className = 'trans-cell';
      cell.textContent = val ? `${val.toFixed(0)}%` : '—';
      cell.style.background = val > 0 ? `rgba(100,200,200,${val/100 * 0.3})` : 'transparent';
      td.appendChild(cell);
      tr.appendChild(td);
    });
    const tdN = document.createElement('td');
    tdN.textContent = trans[from].total;
    tdN.style.opacity = '0.5';
    tr.appendChild(tdN);
    tbody.appendChild(tr);
  });

  // === Recommendations ===
  const recoList = document.getElementById('reco-list');
  const recoIcons = {schedule:'📅', tools:'🔧', sizing:'📊', creative:'🎨', streak:'🔥'};
  recos.forEach(r => {
    const card = document.createElement('div');
    card.className = 'reco-card';
    card.innerHTML = `
      <span class="reco-icon">${recoIcons[r.type]||'💡'}</span>
      <div class="reco-body">
        <div class="reco-insight">${r.insight}</div>
        <div class="reco-action">${r.action}</div>
      </div>
    `;
    recoList.appendChild(card);
  });
</script>

</BaseLayout>
