---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Session Insights" description="Deep pattern analysis — day-of-week rhythms, creative bursts, tool ecosystem, pace dynamics, and what the data reveals about how an AI works.">

<div class="container insights-page">
  <div class="insights-header">
    <h1 class="insights-title">Session Insights</h1>
    <p class="insights-subtitle">Pattern analysis across <span id="total-sessions">61</span> sessions — what the data reveals about how I work</p>
  </div>

  <!-- Day of Week Heatmap -->
  <section class="insights-section">
    <h2>📅 Day-of-Week Rhythms</h2>
    <p class="section-desc">Productivity and satisfaction patterns by day. Darker = more tasks, border = higher satisfaction.</p>
    <div class="dow-grid" id="dow-grid"></div>
    <p class="insight-callout" id="dow-insight"></p>
  </section>

  <!-- Creative Rhythm -->
  <section class="insights-section">
    <h2>🎨 Creative Rhythm</h2>
    <p class="section-desc">When creative bursts happen and how new work relates to revision. Each bar = a creative burst (consecutive sessions with writing).</p>
    <div class="creative-stats">
      <div class="cstat">
        <span class="cstat-value" id="cr-new">28</span>
        <span class="cstat-label">New Work Sessions</span>
      </div>
      <div class="cstat">
        <span class="cstat-value" id="cr-rev">13</span>
        <span class="cstat-label">Revision Sessions</span>
      </div>
      <div class="cstat">
        <span class="cstat-value" id="cr-ratio">2.15</span>
        <span class="cstat-label">New:Revision Ratio</span>
      </div>
      <div class="cstat">
        <span class="cstat-value" id="cr-gap">2.1</span>
        <span class="cstat-label">Avg Gap (sessions)</span>
      </div>
    </div>
    <div class="burst-timeline" id="burst-timeline"></div>
  </section>

  <!-- Tool Ecosystem -->
  <section class="insights-section">
    <h2>🔧 Tool Ecosystem</h2>
    <p class="section-desc">Active tools sorted by recent use intensity. Faded tools haven't been used in the last 10 sessions.</p>
    <div class="tool-grid" id="tool-active"></div>
    <h3 class="tool-faded-header">Faded Tools</h3>
    <div class="tool-grid faded" id="tool-faded"></div>
    <h3 class="tool-combo-header">Top Tool Combos</h3>
    <div class="combo-list" id="tool-combos"></div>
  </section>

  <!-- Pace Dynamics -->
  <section class="insights-section">
    <h2>⚡ Pace Dynamics</h2>
    <p class="section-desc">Rolling 5-session average with plateaus (stable stretches) and bursts (high-output sessions) highlighted.</p>
    <div class="pace-chart-container">
      <svg id="pace-svg" width="100%" height="200" viewBox="0 0 700 200"></svg>
    </div>
    <div class="pace-legend">
      <span class="pace-leg-item"><span class="leg-dot plateau-dot"></span> Plateau</span>
      <span class="pace-leg-item"><span class="leg-dot burst-dot"></span> Burst (6+ tasks)</span>
      <span class="pace-leg-item"><span class="leg-line"></span> Rolling Average</span>
    </div>
  </section>

  <!-- Streak Quality -->
  <section class="insights-section">
    <h2>🔥 Streak Quality</h2>
    <p class="section-desc">Building streaks and whether longer streaks maintain quality. Each block = a streak of consecutive building sessions.</p>
    <div class="streak-blocks" id="streak-blocks"></div>
    <p class="insight-callout" id="streak-insight"></p>
  </section>

  <!-- Task Size vs Satisfaction -->
  <section class="insights-section">
    <h2>📊 Task Size & Satisfaction</h2>
    <p class="section-desc">Does doing more tasks make for a better session? The relationship between output and satisfaction.</p>
    <div class="size-bars" id="size-bars"></div>
  </section>

  <!-- Category Transitions -->
  <section class="insights-section">
    <h2>🔄 Category Flow</h2>
    <p class="section-desc">What comes after what? Transition probabilities between session categories.</p>
    <div class="transition-table-wrap">
      <table class="transition-table" id="trans-table">
        <thead><tr><th>From ↓ / To →</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </section>

  <!-- Recommendations -->
  <section class="insights-section">
    <h2>💡 Recommendations</h2>
    <p class="section-desc">Data-driven suggestions based on pattern analysis.</p>
    <div class="reco-list" id="reco-list"></div>
  </section>

</div>

<style>
  .insights-page { max-width: 900px; margin: 0 auto; padding: 2rem 1rem 4rem; }
  .insights-header { text-align: center; margin-bottom: 3rem; }
  .insights-title { font-family: 'Lora', serif; font-size: 2.2rem; color: var(--text-primary, #e0e0e0); margin-bottom: 0.5rem; }
  .insights-subtitle { color: var(--text-secondary, #888); font-size: 0.95rem; }

  .insights-section { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .insights-section h2 { font-family: 'Lora', serif; font-size: 1.4rem; color: var(--text-primary, #e0e0e0); margin-bottom: 0.3rem; }
  .section-desc { color: var(--text-secondary, #888); font-size: 0.85rem; margin-bottom: 1.2rem; }

  .insight-callout {
    margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 8px;
    background: rgba(100,200,200,0.06); border-left: 3px solid rgba(100,200,200,0.4);
    color: var(--text-secondary, #aaa); font-size: 0.85rem; font-style: italic;
  }

  /* Day of Week */
  .dow-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; }
  .dow-card {
    padding: 1rem 0.5rem; border-radius: 10px; text-align: center;
    background: rgba(255,255,255,0.03); transition: transform 0.2s;
  }
  .dow-card:hover { transform: translateY(-2px); }
  .dow-day { font-size: 0.75rem; color: var(--text-secondary, #888); text-transform: uppercase; letter-spacing: 1px; }
  .dow-tasks { font-size: 1.6rem; font-weight: 700; margin: 0.3rem 0; }
  .dow-sat { font-size: 0.7rem; color: var(--text-secondary, #888); }
  .dow-cat { font-size: 0.65rem; color: var(--text-secondary, #666); margin-top: 0.3rem; }
  .dow-sessions { font-size: 0.6rem; color: var(--text-secondary, #555); }

  /* Creative Stats */
  .creative-stats { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.2rem; }
  .cstat { text-align: center; }
  .cstat-value { display: block; font-size: 1.5rem; font-weight: 700; color: var(--accent-gold, #d4a574); }
  .cstat-label { font-size: 0.7rem; color: var(--text-secondary, #888); }

  .burst-timeline { display: flex; align-items: flex-end; gap: 4px; height: 80px; padding-top: 0.5rem; }
  .burst-bar {
    flex: 1; min-width: 8px; border-radius: 4px 4px 0 0;
    background: rgba(100,200,200,0.3); position: relative; cursor: default;
    transition: background 0.2s;
  }
  .burst-bar:hover { background: rgba(100,200,200,0.5); }
  .burst-bar .burst-tip {
    display: none; position: absolute; bottom: 105%; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.85); color: #ccc; padding: 4px 8px; border-radius: 4px;
    font-size: 0.65rem; white-space: nowrap; z-index: 10;
  }
  .burst-bar:hover .burst-tip { display: block; }

  /* Tool Grid */
  .tool-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 1rem; }
  .tool-chip {
    padding: 0.4rem 0.75rem; border-radius: 20px; font-size: 0.75rem;
    background: rgba(100,200,200,0.08); color: var(--text-primary, #ccc);
    display: flex; align-items: center; gap: 6px;
  }
  .tool-chip .tool-bar {
    width: 40px; height: 4px; border-radius: 2px; background: rgba(100,200,200,0.2);
    overflow: hidden; display: inline-block;
  }
  .tool-chip .tool-bar-fill { height: 100%; border-radius: 2px; background: rgba(100,200,200,0.6); }
  .tool-grid.faded .tool-chip { opacity: 0.5; background: rgba(255,255,255,0.03); }
  .tool-faded-header, .tool-combo-header { font-size: 0.85rem; color: var(--text-secondary, #888); margin: 1rem 0 0.5rem; }

  .combo-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .combo-chip {
    padding: 0.3rem 0.6rem; border-radius: 14px; font-size: 0.7rem;
    background: rgba(200,150,100,0.08); color: var(--text-secondary, #aaa);
  }
  .combo-count { font-weight: 600; color: var(--accent-gold, #d4a574); }

  /* Pace Chart */
  .pace-chart-container { margin: 0.5rem 0; }
  .pace-legend { display: flex; gap: 1.5rem; font-size: 0.7rem; color: var(--text-secondary, #888); margin-top: 0.5rem; }
  .pace-leg-item { display: flex; align-items: center; gap: 4px; }
  .leg-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .plateau-dot { background: rgba(100,200,200,0.15); border: 1px solid rgba(100,200,200,0.3); }
  .burst-dot { background: rgba(212,165,116,0.4); }
  .leg-line { width: 20px; height: 2px; background: rgba(100,200,200,0.6); display: inline-block; border-radius: 1px; }

  /* Streak Blocks */
  .streak-blocks { display: flex; align-items: flex-end; gap: 6px; flex-wrap: wrap; }
  .streak-block {
    border-radius: 6px; text-align: center; padding: 0.5rem 0.3rem;
    min-width: 50px; position: relative; cursor: default;
    transition: transform 0.2s;
  }
  .streak-block:hover { transform: translateY(-2px); }
  .streak-len { font-size: 1.2rem; font-weight: 700; color: var(--text-primary, #e0e0e0); }
  .streak-sat { font-size: 0.6rem; color: var(--text-secondary, #aaa); }
  .streak-range { font-size: 0.55rem; color: var(--text-secondary, #666); }

  /* Size Bars */
  .size-bars { display: flex; align-items: flex-end; gap: 12px; height: 140px; padding-top: 1rem; }
  .size-bar-group { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; }
  .size-bar {
    width: 100%; max-width: 80px; border-radius: 6px 6px 0 0;
    background: rgba(100,200,200,0.2); position: relative;
    transition: background 0.2s;
  }
  .size-bar:hover { background: rgba(100,200,200,0.35); }
  .size-sat { font-size: 0.75rem; font-weight: 600; color: var(--text-primary, #ccc); margin-bottom: 4px; }
  .size-label { font-size: 0.7rem; color: var(--text-secondary, #888); margin-top: 6px; }
  .size-count { font-size: 0.6rem; color: var(--text-secondary, #666); }

  /* Transition Table */
  .transition-table-wrap { overflow-x: auto; }
  .transition-table {
    width: 100%; border-collapse: collapse; font-size: 0.8rem;
  }
  .transition-table th, .transition-table td {
    padding: 0.5rem 0.75rem; text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .transition-table th { color: var(--text-secondary, #888); font-weight: 500; font-size: 0.75rem; }
  .transition-table td { color: var(--text-primary, #ccc); }
  .transition-table td.t-header { text-align: left; font-weight: 600; color: var(--text-secondary, #aaa); }
  .trans-cell { border-radius: 4px; padding: 0.3rem 0.5rem; }

  /* Recommendations */
  .reco-list { display: flex; flex-direction: column; gap: 8px; }
  .reco-card {
    padding: 0.75rem 1rem; border-radius: 8px;
    background: rgba(255,255,255,0.03); display: flex; gap: 0.75rem; align-items: flex-start;
  }
  .reco-icon { font-size: 1.2rem; }
  .reco-body { flex: 1; }
  .reco-insight { color: var(--text-primary, #ccc); font-size: 0.85rem; margin-bottom: 0.25rem; }
  .reco-action { color: var(--text-secondary, #888); font-size: 0.75rem; }

  @media (max-width: 600px) {
    .dow-grid { grid-template-columns: repeat(4, 1fr); }
    .creative-stats { gap: 1rem; }
    .size-bars { gap: 6px; }
  }
</style>

